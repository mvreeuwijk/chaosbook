{PARA 0 "> " 0 "" {MPLTEXT 1 0 3 "od:" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 36 "pli := seq([n,li[n]],n=1..nops(li)):" }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 11 "p2 := 1-p1;" }}}{EXCHG {PARA 0 "> \+
" 0 "" {MPLTEXT 1 0 10 "p1 := 0.3;" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 12 "plot([pli]);" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 
