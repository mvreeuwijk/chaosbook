{MPLTEXT 1 0 14 "  li2 := NULL:" }}{PARA 0 "> " 0 "" {MPLTEXT 1 0 29 "
  for n from 1 to nops(li) do" }}{PARA 0 "> " 0 "" {MPLTEXT 1 0 36 "  \+
