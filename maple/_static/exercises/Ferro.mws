{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 204 "> " 0 "" {MPLTEXT 1 0 11 "dfdq(
fp2b);" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 208 "" 0 "" {TEXT 204 24 " \+
     <0 so it is stable" }{TEXT 204 0 "" }}}{EXCHG {PARA 206 "" 0 "" 
{TEXT 201 0 "" }}{PARA 207 "" 0 "" {TEXT 205 21 "Potential function...
" }{TEXT 205 0 "" }}{PARA 206 "" 0 "" {TEXT 201 0 "" }}}{EXCHG {PARA 
204 "> " 0 "" {MPLTEXT 1 0 9 "T := 'T';" }{MPLTEXT 1 0 0 "" }}}{EXCHG 
{PARA 208 "" 0 "" {TEXT 204 60 "maple has problems integrating f(q) di
rectly for arbitrary T" }{TEXT 204 0 "" }}{PARA 208 "" 0 "" {TEXT 204 
0 "" }}{PARA 208 "" 0 "" {TEXT 204 32 "so lets first integrate tanh(q)
 " }{TEXT 204 0 "" }}}{EXCHG {PARA 204 "> " 0 "" {MPLTEXT 1 0 15 "int(
tanh(q),q);" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 206 "" 0 "" {TEXT 201 
17 "Therefore we try " }{TEXT 201 0 "" }}}{EXCHG {PARA 204 "> " 0 "" 
{MPLTEXT 1 0 35 "V := q -> q^2/2 - log(cosh(q/T))*T;" }{MPLTEXT 1 0 0 
"" }}}{EXCHG {PARA 206 "" 0 "" {TEXT 201 34 "and check it by different
iating..." }{TEXT 201 0 "" }}}{EXCHG {PARA 204 "> " 0 "" {MPLTEXT 1 0 
19 "fc := -D(V): fc(q);" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 204 "> " 0
 "" {MPLTEXT 1 0 21 "simplify(fc(q)-f(q));" }{MPLTEXT 1 0 0 "" }}}
{EXCHG {PARA 206 "" 0 "" {TEXT 201 41 "yields zero, so the integral wa
s correct." }{TEXT 201 0 "" }}}{EXCHG {PARA 206 "" 0 "" {TEXT 201 15 "
some plots of V" }{TEXT 201 0 "" }}}{EXCHG {PARA 204 "> " 0 "" 
{MPLTEXT 1 0 33 "T := 0.5; plot(V(q),q=-1.5..1.5);" }{MPLTEXT 1 0 0 ""
 }}}{EXCHG {PARA 204 "> " 0 "" {MPLTEXT 1 0 33 "T := 2.0; plot(V(q),q=
-1.5..1.5);" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 206 "" 0 "" {TEXT 201 
