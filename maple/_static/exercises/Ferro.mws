s):" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 205 "" 0 "" {TEXT 206 25 "Ferr
omagnetic Spin System" }{TEXT 206 0 "" }}}{EXCHG {PARA 206 "" 0 "" 
{TEXT 201 0 "" }}{PARA 207 "" 0 "" {TEXT 205 18 "Geometric approach" }
{TEXT 205 0 "" }}{PARA 206 "" 0 "" {TEXT 201 0 "" }}}{EXCHG {PARA 206 
"" 0 "" {TEXT 201 20 "Define the function " }{TEXT 201 0 "" }}}{EXCHG 
{PARA 204 "> " 0 "" {MPLTEXT 1 0 25 "f := q -> -q + tanh(q/T);" }
{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 206 "" 0 "" {TEXT 201 47 "Plot is fo
r various values of the temperature T" }{TEXT 201 0 "" }}}{EXCHG 
{PARA 204 "> " 0 "" {MPLTEXT 1 0 30 "T := 0.5; plot(f(q), q=-1..1);" }
{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 204 "> " 0 "" {MPLTEXT 1 0 30 "T := \+
0.9; plot(f(q), q=-1..1);" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 204 "> "
 0 "" {MPLTEXT 1 0 30 "T := 1.0; plot(f(q), q=-1..1);" }{MPLTEXT 1 0 
0 "" }}}{EXCHG {PARA 204 "> " 0 "" {MPLTEXT 1 0 30 "T := 1.1; plot(f(q
), q=-1..1);" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 204 "> " 0 "" 
{MPLTEXT 1 0 30 "T := 2.0; plot(f(q), q=-1..1);" }{MPLTEXT 1 0 0 "" }}
}{EXCHG {PARA 206 "" 0 "" {TEXT 201 48 "Or use the \"animate\" command
 to make a movie ..." }{TEXT 201 0 "" }}}{EXCHG {PARA 204 "> " 0 "" 
{MPLTEXT 1 0 7 "T:='T';" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 206 "" 0 "
" {TEXT 201 73 "put cursor in the plot below and press the play button
 in the menu above " }{TEXT 201 0 "" }}}{EXCHG {PARA 204 "> " 0 "" 
{MPLTEXT 1 0 33 "animate(f(q),q=-1..1,T=0.1..2.0);" }{MPLTEXT 1 0 0 ""
 }}}{EXCHG {PARA 206 "" 0 "" {TEXT 201 108 "The plots show that for T \+
in [0,1) there are three fixed points, but for T>1 there is only one f
ixed point. " }{TEXT 201 0 "" }}{PARA 206 "" 0 "" {TEXT 201 114 "The g
eometric approach also shows that for T < 1, the fixed point q=0 is un
stable, the other two are both stable. " }{TEXT 201 0 "" }}{PARA 206 "
" 0 "" {TEXT 201 50 "For T>1 the fixed point x=0 is (globally) stable.
 " }{TEXT 201 0 "" }}}{EXCHG {PARA 206 "" 0 "" {TEXT 201 0 "" }}{PARA 
207 "" 0 "" {TEXT 205 25 "Linear stability analysis" }{TEXT 205 0 "" }
}{PARA 206 "" 0 "" {TEXT 201 0 "" }}}{EXCHG {PARA 206 "" 0 "" {TEXT 
201 30 "1. find fixed points for T=1/2" }{TEXT 201 0 "" }}}{EXCHG 
{PARA 204 "> " 0 "" {MPLTEXT 1 0 9 "T := 0.5;" }{MPLTEXT 1 0 0 "" }}}
{EXCHG {PARA 204 "> " 0 "" {MPLTEXT 1 0 32 "fp1a := fsolve(f(q)=0,q,0.
1..2);" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 204 "> " 0 "" {MPLTEXT 1 0 
39 "fp1b := 0.0;       #trivial fixed point" }{MPLTEXT 1 0 0 "" }}}
{EXCHG {PARA 208 "" 0 "" {TEXT 204 39 "2. differentiate to determine s
tability" }{TEXT 204 0 "" }}{PARA 204 "> " 0 "" {MPLTEXT 1 0 13 "dfdq \+
:= D(f);" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 204 "> " 0 "" {MPLTEXT 1 
0 18 "evalf(dfdq(fp1a));" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 208 "" 0 
"" {TEXT 204 24 "      <0 so it is stable" }{TEXT 204 0 "" }}{PARA 
204 "> " 0 "" {MPLTEXT 1 0 18 "evalf(dfdq(fp1b));" }{MPLTEXT 1 0 0 "" 
}}}{EXCHG {PARA 208 "" 0 "" {TEXT 204 26 "      >0 so it is unstable" 
}{TEXT 204 0 "" }}}{EXCHG {PARA 208 "" 0 "" {TEXT 204 0 "" }}{PARA 
