{SECT 0 {EXCHG {PARA 200 "> " 0 "" {MPLTEXT 1 204 21 "restart: with(pl
ots):" }{MPLTEXT 1 204 0 "" }}}{EXCHG {PARA 201 "" 0 "" {TEXT 205 61 "
The number of segments scales with the recursion depth n as: " }{TEXT 
205 0 "" }}{PARA 201 "" 0 "" {TEXT 205 7 "N = 3^n" }{TEXT 205 0 "" }}
{PARA 201 "" 0 "" {TEXT 205 50 "The size l of the \"yardstick\" (or bo
x) scales as: " }{TEXT 205 0 "" }}{PARA 201 "" 0 "" {TEXT 205 7 "l = a
^n" }{TEXT 205 0 "" }}{PARA 201 "" 0 "" {TEXT 205 0 "" }}{PARA 201 "" 
0 "" {TEXT 205 40 "Expressed in a the fractal dimension is " }{TEXT 
205 0 "" }}{PARA 201 "" 0 "" {TEXT 205 0 "" }}{PARA 201 "" 0 "" {TEXT 
205 19 "d = -log(3)/log(a) " }{TEXT 205 0 "" }}{PARA 200 "> " 0 "" 
{MPLTEXT 1 204 20 "d := -log(3)/log(a);" }{MPLTEXT 1 204 0 "" }}}
{EXCHG {PARA 201 "" 0 "" {TEXT 205 46 "The locations of the points of \+
the curves are " }{TEXT 205 0 "" }}{PARA 200 "> " 0 "" {MPLTEXT 1 204 
35 "x1 := a*cos(phi); y1 := a*sin(phi);" }{MPLTEXT 1 204 0 "" }}}
{EXCHG {PARA 200 "> " 0 "" {MPLTEXT 1 204 38 "x2 := 1-a*cos(phi); y2 :
= -a*sin(phi);" }{MPLTEXT 1 204 0 "" }}}{EXCHG {PARA 201 "" 0 "" 
{TEXT 205 60 "Since the segments are equally sized, we obtain the equa
tion" }{TEXT 205 0 "" }}{PARA 200 "> " 0 "" {MPLTEXT 1 204 34 "eq := a
^2 = (x2-x1)^2 + (y2-y1)^2;" }{MPLTEXT 1 204 0 "" }}}{EXCHG {PARA 200 
"> " 0 "" {MPLTEXT 1 204 20 "sols := solve(eq,a);" }{MPLTEXT 1 204 0 "
" }}}{EXCHG {PARA 201 "" 0 "" {TEXT 205 51 "The first does not comply \+
with a cos(phi) <= 1/2 so" }{TEXT 205 0 "" }}{PARA 200 "> " 0 "" 
{MPLTEXT 1 204 45 "a := 2/3*cos(phi)-1/3*(4*cos(phi)^2-3)^(1/2);" }
{MPLTEXT 1 204 0 "" }}}{EXCHG {PARA 201 "" 0 "" {TEXT 205 5 "Hence" }
{TEXT 205 0 "" }}{PARA 200 "> " 0 "" {MPLTEXT 1 204 2 "d;" }{MPLTEXT 
1 204 0 "" }}}{EXCHG {PARA 200 "> " 0 "" {MPLTEXT 1 204 86 "plot(d,phi
=0..Pi/6,labels=[\"phi\",\"d\"],title=\"fractal dimension as a functio
n of phi\");" }{MPLTEXT 1 204 0 "" }}}{EXCHG {PARA 201 "" 0 "" {TEXT 
205 0 "" }}{PARA 201 "" 0 "" {TEXT 205 49 "The total length L of the c
urve scales with n as " }{TEXT 205 0 "" }}{PARA 201 "" 0 "" {TEXT 205 
11 "L = (3a)^n " }{TEXT 205 0 "" }}{PARA 201 "" 0 "" {TEXT 205 1 " " }
{TEXT 205 0 "" }}{PARA 201 "" 0 "" {TEXT 205 23 "so we must solve n fr
om" }{TEXT 205 0 "" }}}{EXCHG {PARA 200 "> " 0 "" {MPLTEXT 1 204 24 "n
 := log(1000)/log(3*a);" }{MPLTEXT 1 204 0 "" }}}{EXCHG {PARA 200 "> "
 0 "" {MPLTEXT 1 204 12 "phi := Pi/7;" }{MPLTEXT 1 204 0 "" }}}{EXCHG 
{PARA 200 "> " 0 "" {MPLTEXT 1 204 9 "evalf(n);" }{MPLTEXT 1 204 0 "" 
}}}{EXCHG {PARA 201 "" 0 "" {TEXT 205 51 "After 26 recursions, the len
gth is larger then 1 km" }{TEXT 205 0 "" }}{PARA 201 "" 0 "" {TEXT 
205 41 "(but still confined within the 1m range!)" }{TEXT 205 0 "" }}}
{EXCHG {PARA 200 "> " 0 "" {MPLTEXT 1 204 21 "restart: with(plots):" }
{MPLTEXT 1 204 0 "" }}}{EXCHG {PARA 200 "> " 0 "" {MPLTEXT 1 204 25 "r
ead \"FractalCurve.data\":" }{MPLTEXT 1 204 0 "" }}}{EXCHG {PARA 200 "
> " 0 "" {MPLTEXT 1 204 14 "N:=nops(data);" }{MPLTEXT 1 204 0 "" }}}
