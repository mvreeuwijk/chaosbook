" 0 "" {TEXT 205 0 "" }}{PARA 201 "" 0 "" {TEXT 205 47 "Firstly, fit n
eeds lists of x and y separately." }{TEXT 205 0 "" }}{PARA 200 "> " 0 
"" {MPLTEXT 1 204 43 "xli := seq(log(li[i][1]), i=1..nops([li]));" }
{MPLTEXT 1 204 0 "" }}}{EXCHG {PARA 200 "> " 0 "" {MPLTEXT 1 204 43 "y
