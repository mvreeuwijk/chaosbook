 {MPLTEXT 1 201 32 "pmin := 1; pmax := 7; dp := 0.5;" }{MPLTEXT 1 201 
0 "" }}}{EXCHG {PARA 233 "" 0 "" {TEXT -1 0 "" }}{PARA 233 "" 0 "" 
{TEXT -1 50 "here is the main part of the boxcounting procedure" }
{TEXT -1 0 "" }}{PARA 233 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 232 ">
 " 0 "" {MPLTEXT 1 201 33 "for p from pmin to pmax by dp do " }
{MPLTEXT 1 201 0 "" }}{PARA 228 "> " 0 "" {MPLTEXT 1 0 0 "" }}{PARA 
232 "> " 0 "" {MPLTEXT 1 201 27 "  delta := (xmax-xmin)/2^p;" }
{MPLTEXT 1 201 0 "" }}{PARA 232 "> " 0 "" {MPLTEXT 1 201 35 "  ni := t
runc((xmax-xmin)/delta)+1;" }{MPLTEXT 1 201 0 "" }}{PARA 232 "> " 0 ""
 {MPLTEXT 1 201 35 "  nj := trunc((ymax-ymin)/delta)+1;" }{MPLTEXT 1 
201 0 "" }}{PARA 232 "> " 0 "" {MPLTEXT 1 201 23 "  print(p,ni,nj,delt
a);" }{MPLTEXT 1 201 0 "" }}{PARA 232 "> " 0 "" {MPLTEXT 1 201 30 "  n
