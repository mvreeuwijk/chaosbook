 }{MPLTEXT 1 201 0 "" }}{PARA 232 "> " 0 "" {MPLTEXT 1 201 13 "  boxes
 := 0;" }{MPLTEXT 1 201 0 "" }}{PARA 232 "> " 0 "" {MPLTEXT 1 201 23 "
  for i from 1 to ni do" }{MPLTEXT 1 201 0 "" }}{PARA 232 "> " 0 "" 
{MPLTEXT 1 201 25 "    for j from 1 to nj do" }{MPLTEXT 1 201 0 "" }}
