> " 0 "" {MPLTEXT 1 201 30 "xmin := min(seq(x[n],n=1..N));" }{MPLTEXT 
1 201 0 "" }}}{EXCHG {PARA 233 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 
232 "> " 0 "" {MPLTEXT 1 201 55 "i := 'i'; j := 'j'; p := 'p'; li := N
