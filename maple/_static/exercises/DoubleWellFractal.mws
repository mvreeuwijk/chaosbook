{SECT 0 {EXCHG {PARA 226 "> " 0 "" {MPLTEXT 1 217 34 "restart; with(pl
ots): with(stats):" }}}{EXCHG {PARA 226 "> " 0 "" {MPLTEXT 1 217 21 "f
1 := (x, y, z) -> y;" }{MPLTEXT 1 217 0 "" }}{PARA 226 "> " 0 "" 
{MPLTEXT 1 217 47 "f2 := (x, y, z) -> -f * y + x - x^3 + A*cos(z);" }
{MPLTEXT 1 217 0 "" }}{PARA 226 "> " 0 "" {MPLTEXT 1 217 25 "f3 := (x,
 y, z) -> omega;" }{MPLTEXT 1 217 0 "" }}}{EXCHG {PARA 226 "> " 0 "" 
{MPLTEXT 1 217 44 "de1 := diff(x(t), t) = f1(x(t), y(t), z(t));" }
{MPLTEXT 1 217 0 "" }}{PARA 226 "> " 0 "" {MPLTEXT 1 217 44 "de2 := di
ff(y(t), t) = f2(x(t), y(t), z(t));" }{MPLTEXT 1 217 0 "" }}{PARA 226 
"> " 0 "" {MPLTEXT 1 217 44 "de3 := diff(z(t), t) = f3(x(t), y(t), z(t
));" }{MPLTEXT 1 217 0 "" }}{PARA 226 "> " 0 "" {MPLTEXT 1 217 21 "sys
 := de1, de2, de3;" }{MPLTEXT 1 217 0 "" }}}{EXCHG {PARA 227 "> " 0 ""
 {MPLTEXT 1 -1 31 "A := 0.3; f:= 0.15; omega := 1;" }{MPLTEXT 1 -1 0 "
" }}}{EXCHG {PARA 228 "> " 0 "" {MPLTEXT 1 0 35 "ic := x(0) = 0, y(0) \+
= 0, z(0) = 0;" }}}{EXCHG {PARA 229 "> " 0 "" {MPLTEXT 1 209 10 "N := \+
5000;" }{MPLTEXT 1 209 0 "" }}{PARA 229 "> " 0 "" {MPLTEXT 1 209 28 "d
t := evalf(2 * Pi / omega);" }{MPLTEXT 1 209 0 "" }}}{EXCHG {PARA 228 
"> " 0 "" {MPLTEXT 1 0 28 "tlist := [seq(i*dt,i=1..N)];" }{MPLTEXT 1 
0 0 "" }}}{EXCHG {PARA 229 "> " 0 "" {MPLTEXT 1 209 19 "tt := Array(tl
ist);" }{MPLTEXT 1 209 0 "" }}{PARA 229 "> " 0 "" {MPLTEXT 1 209 60 "s
ol := dsolve(\{sys, ic\}, type=numeric, maxfun=-1,output=tt):" }
{MPLTEXT 1 209 0 "" }}{PARA 229 "> " 0 "" {MPLTEXT 1 209 18 "soldd := \+
sol[2,1];" }{MPLTEXT 1 209 0 "" }}{PARA 229 "> " 0 "" {MPLTEXT 1 209 
21 "xx := soldd[1..N, 2];" }{MPLTEXT 1 209 0 "" }}{PARA 229 "> " 0 "" 
{MPLTEXT 1 209 20 "yy := soldd[1..N,3];" }{MPLTEXT 1 209 0 "" }}}
{EXCHG {PARA 229 "> " 0 "" {MPLTEXT 1 209 36 "pp := seq([xx[i], yy[i]]
, i=N/2..N):" }{MPLTEXT 1 209 0 "" }}{PARA 229 "> " 0 "" {MPLTEXT 1 
