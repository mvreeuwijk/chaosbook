ma of the set" }{TEXT 208 0 "" }}{PARA 204 "" 0 "" {TEXT 208 0 "" }}}
{EXCHG {PARA 202 "> " 0 "" {MPLTEXT 1 0 30 "xmax := max(seq(x[n],n=1..
N));" }{MPLTEXT 1 0 0 "" }}{PARA 202 "> " 0 "" {MPLTEXT 1 0 30 "xmin :
= min(seq(x[n],n=1..N));" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 204 "" 0 
"" {TEXT 208 0 "" }}}{EXCHG {PARA 202 "> " 0 "" {MPLTEXT 1 0 45 "i := \+
'i'; p := 'p'; li := NULL; loli := NULL:" }{MPLTEXT 1 0 0 "" }}}
{EXCHG {PARA 202 "> " 0 "" {MPLTEXT 1 0 30 "pmin := 1; pmax := 5; dp :
= 1;" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 204 "" 0 "" {TEXT 208 0 "" }}
{PARA 204 "" 0 "" {TEXT 208 50 "here is the main part of the boxcounti
ng procedure" }{TEXT 208 0 "" }}{PARA 204 "" 0 "" {TEXT 208 0 "" }}}
{EXCHG {PARA 202 "> " 0 "" {MPLTEXT 1 0 32 "for p from pmin to pmax by
 dp do" }{MPLTEXT 1 0 0 "" }}{PARA 202 "> " 0 "" {MPLTEXT 1 0 0 "" }}
{PARA 202 "> " 0 "" {MPLTEXT 1 0 18 "  delta := 3^(-p);" }{MPLTEXT 1 
0 0 "" }}{PARA 202 "> " 0 "" {MPLTEXT 1 0 35 "  ni := trunc((xmax-xmin
)/delta)+1;" }{MPLTEXT 1 0 0 "" }}{PARA 202 "> " 0 "" {MPLTEXT 1 0 20 
