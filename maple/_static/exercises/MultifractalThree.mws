{MPLTEXT 1 0 24 "  nr := Vector(1..ni,0);" }{MPLTEXT 1 0 0 "" }}{PARA 
202 "> " 0 "" {MPLTEXT 1 0 0 "" }}{PARA 202 "> " 0 "" {MPLTEXT 1 0 22 
"  for n from 1 to N do" }{MPLTEXT 1 0 0 "" }}{PARA 202 "> " 0 "" 
{MPLTEXT 1 0 36 "    i := trunc((x[n]-xmin)/delta)+1;" }{MPLTEXT 1 0 
0 "" }}{PARA 202 "> " 0 "" {MPLTEXT 1 0 26 "    nr[i] := nr[i]+dat[n];
" }{MPLTEXT 1 0 0 "" }}{PARA 202 "> " 0 "" {MPLTEXT 1 0 5 "  od:" }
{MPLTEXT 1 0 0 "" }}{PARA 202 "> " 0 "" {MPLTEXT 1 0 0 "" }}{PARA 202 
"> " 0 "" {MPLTEXT 1 0 11 "  i := 'i';" }{MPLTEXT 1 0 0 "" }}{PARA 
