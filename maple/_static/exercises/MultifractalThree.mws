}{PARA 202 "> " 0 "" {MPLTEXT 1 0 5 "  od;" }{MPLTEXT 1 0 0 "" }}
{PARA 202 "> " 0 "" {MPLTEXT 1 0 0 "" }}{PARA 202 "> " 0 "" {MPLTEXT 
1 0 25 "  li := li,[delta,boxes];" }{MPLTEXT 1 0 0 "" }}{PARA 202 "> "
