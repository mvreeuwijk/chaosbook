 1/2;" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 202 "> " 0 "" {MPLTEXT 1 0 
12 "plot([pli]);" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 204 "" 0 "" 
{TEXT 208 0 "" }}{PARA 204 "" 0 "" {TEXT 208 21 "This is a Cantor set.
" }{TEXT 208 0 "" }}{PARA 204 "" 0 "" {TEXT 208 55 "at level n the num
ber of occupied boxes is: N_n  ~ 2^n " }{TEXT 208 0 "" }}{PARA 204 "" 
0 "" {TEXT 208 51 "at level n the size of the boxes is:  l_n  ~ 3^(-n)
" }{TEXT 208 0 "" }}{PARA 204 "" 0 "" {TEXT 208 66 "The fractal dimens
ion D follows from N_n ~(l_n)^(-D) yielding:    " }{TEXT 210 17 "D = l
og(2)/log(3)" }{TEXT 208 0 "" }}{PARA 204 "" 0 "" {TEXT 208 0 "" }}}
{EXCHG {PARA 206 "" 0 "" {TEXT 211 0 "" }}{PARA 206 "" 0 "" {TEXT 211 
34 "c) calculate generalized dimension" }}{PARA 206 "" 0 "" {TEXT 211 
0 "" }}}{EXCHG {PARA 202 "> " 0 "" {MPLTEXT 1 0 31 "p1 := 4/5; p2 := 0
; p3 := 1-p1;" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 202 "> " 0 "" 
{MPLTEXT 1 0 12 "plot([pli]);" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 202 
"> " 0 "" {MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 204 "" 0 "" {TEXT 208 29 "
The generalised dimension is:" }{TEXT 208 0 "" }}{PARA 204 "" 0 "" 
{TEXT 208 0 "" }}}{EXCHG {PARA 202 "> " 0 "" {MPLTEXT 1 0 35 "p1 := 'p
1'; p2 := 'p2'; p3 := 'p3';" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 202 ">
 " 0 "" {MPLTEXT 1 0 45 "Dq := -(q-1)^(-1)*log(p1^q+p2^q+p3^q)/log(3);
" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 204 "" 0 "" {TEXT 208 39 "with p1
 = 4/5 , p2 = 0, p3 = 1/5 we get" }{TEXT 208 0 "" }}{PARA 204 "" 0 "" 
{TEXT 208 0 "" }}}{EXCHG {PARA 202 "> " 0 "" {MPLTEXT 1 0 62 "Dq := su
bs(\{p1=4/5,p3=1/5\},-(q-1)^(-1)*log(p1^q+p3^q)/log(3));" }{MPLTEXT 1 
0 0 "" }}}{EXCHG {PARA 204 "" 0 "" {TEXT 208 71 "Note that the fractal
 dimension (=D(0)) does not depend on the p-values" }{TEXT 208 0 "" }}
}{EXCHG {PARA 202 "> " 0 "" {MPLTEXT 1 0 13 "subs(q=0,Dq);" }{MPLTEXT 
1 0 0 "" }}}{EXCHG {PARA 204 "" 0 "" {TEXT 208 48 "which is identical \+
to the value determined in b)" }{TEXT 208 0 "" }}}{EXCHG {PARA 207 "" 
0 "" {TEXT 212 0 "" }}{PARA 207 "" 0 "" {TEXT 212 15 "d) box-counting"
 }}{PARA 207 "" 0 "" {TEXT 212 0 "" }}}{EXCHG {PARA 202 "> " 0 "" 
{MPLTEXT 1 0 31 "p1 := 4/5; p2 := 0; p3 := 1-p1;" }{MPLTEXT 1 0 0 "" }
}}{EXCHG {PARA 202 "> " 0 "" {MPLTEXT 1 0 17 "dat := evalf(li):" }
{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 202 "> " 0 "" {MPLTEXT 1 0 14 "N:= n
ops(dat);" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 204 "" 0 "" {TEXT 208 0 
