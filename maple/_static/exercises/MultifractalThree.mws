{PARA 202 "> " 0 "" {MPLTEXT 1 0 23 "  for i from 1 to ni do" }
{MPLTEXT 1 0 0 "" }}{PARA 202 "> " 0 "" {MPLTEXT 1 0 61 "       if( nr
