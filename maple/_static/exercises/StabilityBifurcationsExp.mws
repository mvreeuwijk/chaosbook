{PARA 202 "> " 0 "" {MPLTEXT 1 0 7 "r := 3;" }{MPLTEXT 1 0 0 "" }}}
{EXCHG {PARA 202 "> " 0 "" {MPLTEXT 1 0 19 "plot(f(x),x=-3..1);" }
{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 204 "" 0 "" {TEXT 209 32 "there are \+
three fixed points ..." }{TEXT 209 0 "" }}}{EXCHG {PARA 202 "> " 0 "" 
{MPLTEXT 1 0 32 "x1 := fsolve(f(x),x,-2.1..-1.9);" }{MPLTEXT 1 0 0 "" 
}}}{EXCHG {PARA 202 "> " 0 "" {MPLTEXT 1 0 29 "x2 := fsolve(f(x),x,-1.
2..0);" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 202 "> " 0 "" {MPLTEXT 1 0 
26 "x3 := fsolve(f(x),x,0..1);" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 
