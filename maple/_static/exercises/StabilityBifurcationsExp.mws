s):" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 202 "> " 0 "" {MPLTEXT 1 0 33 
"f := x -> -2 - x + r * exp(-x^2);" }{MPLTEXT 1 0 0 "" }}}{EXCHG 
{PARA 202 "> " 0 "" {MPLTEXT 1 0 11 "df := D(f);" }{MPLTEXT 1 0 0 "" }
}}{EXCHG {PARA 203 "" 0 "" {TEXT 208 0 "" }}{PARA 203 "" 0 "" {TEXT 
