ity ..." }}{PARA 205 "" 0 "" {TEXT 210 0 "" }}}{EXCHG {PARA 202 "> " 0
 "" {MPLTEXT 1 0 7 "df(x1);" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 204 ""
 0 "" {TEXT 209 27 "<0 , therefore x1 is stable" }{TEXT 209 0 "" }}}
{EXCHG {PARA 202 "> " 0 "" {MPLTEXT 1 0 7 "df(x2);" }{MPLTEXT 1 0 0 ""
 }}}{EXCHG {PARA 204 "" 0 "" {TEXT 209 30 "> 0,  therefore x2 is unsta
ble" }{TEXT 209 0 "" }}}{EXCHG {PARA 202 "> " 0 "" {MPLTEXT 1 0 7 "df(
x3);" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 204 "" 0 "" {TEXT 209 26 "<0,
 therefore x3 is stable" }{TEXT 209 0 "" }}}{EXCHG {PARA 206 "" 0 "" 
{TEXT 211 0 "" }}{PARA 206 "" 0 "" {TEXT 211 21 "c) attraction domains
" }}{PARA 206 "" 0 "" {TEXT 211 0 "" }}{PARA 204 "" 0 "" {TEXT 209 39 
