{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 202 "> " 0 "" {MPLTEXT 1 0 146 "plot
([subs(r=-10,f(x)),subs(r=-2,f(x)),subs(r=1,f(x)),subs(r=2,f(x)),subs(
r=5,f(x)),subs(r=10,f(x))],x=-2.5..1,labels=[\"x\",\"f(x,r)\"],thickne
