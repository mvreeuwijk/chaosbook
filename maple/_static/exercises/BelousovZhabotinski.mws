{SECT 0 {EXCHG {PARA 233 "> " 0 "" {MPLTEXT 1 214 42 "restart; with(pl
ots):with(LinearAlgebra): " }{MPLTEXT 1 214 0 "" }}}{EXCHG {PARA 234 "
> " 0 "" {MPLTEXT 1 205 57 "f1 := (x, y, z) -> (z - a * x^3 + b*x^2 - \+
c*x) / epsilon;" }{MPLTEXT 1 205 0 "" }}{PARA 235 "> " 0 "" {MPLTEXT 
1 0 39 "f2 := (x, y, z) -> y * (z + s * x - l);" }{MPLTEXT 1 0 0 "" }}
{PARA 234 "> " 0 "" {MPLTEXT 1 205 47 "f3 := (x, y, z) -> z * (d * z -
 f * y - x + g);" }{MPLTEXT 1 205 0 "" }}}{EXCHG {PARA 235 "> " 0 "" 
{MPLTEXT 1 0 82 "a := 0.5; b := 3; c := 5; f := 0.5; g := 0.6; l := 1.
3; s := 0.3; epsilon := 0.01;" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 235 
"> " 0 "" {MPLTEXT 1 0 44 "de1 := diff(x(t), t) = f1(x(t), y(t), z(t))
;" }{MPLTEXT 1 0 0 "" }}{PARA 235 "> " 0 "" {MPLTEXT 1 0 44 "de2 := di
ff(y(t), t) = f2(x(t), y(t), z(t));" }{MPLTEXT 1 0 0 "" }}{PARA 235 ">
 " 0 "" {MPLTEXT 1 0 44 "de3 := diff(z(t), t) = f3(x(t), y(t), z(t));"
 }{MPLTEXT 1 0 0 "" }}{PARA 234 "> " 0 "" {MPLTEXT 1 205 21 "sys := de
1, de2, de3;" }{MPLTEXT 1 205 0 "" }}}{EXCHG {PARA 235 "> " 0 "" 
{MPLTEXT 1 0 35 "ic := x(0) = 1, y(0) = 1, z(0) = 1;" }{MPLTEXT 1 0 0 
"" }}}{EXCHG {PARA 236 "" 0 "" {TEXT 203 0 "" }}{PARA 236 "" 0 "" 
{TEXT 203 45 "a. Plot a time series with periodic behavior." }{TEXT 
203 0 "" }}{PARA 237 "" 0 "" {TEXT 212 0 "" }}}{EXCHG {PARA 234 "> " 0
 "" {MPLTEXT 1 205 22 "d := 0.3; tend := 300;" }{MPLTEXT 1 205 0 "" }}
{PARA 235 "> " 0 "" {MPLTEXT 1 0 71 "sol := dsolve(\{sys, ic\}, type=n
umeric, maxfun=-1,output=listprocedure);" }{MPLTEXT 1 0 0 "" }}{PARA 
234 "> " 0 "" {MPLTEXT 1 205 93 "odeplot(sol, [t, y(t)], 0..tend, labe
ls=[\"t\",\"y\"],numpoints=tend*100,color=blue,axes=normal);" }
{MPLTEXT 1 205 0 "" }}}{EXCHG {PARA 237 "" 0 "" {TEXT 212 0 "" }}
{PARA 236 "" 0 "" {TEXT 203 39 "b. Vary d and characterize the regimes
," }{TEXT 203 0 "" }}{PARA 237 "" 0 "" {TEXT 212 0 "" }}}{EXCHG {PARA 
235 "> " 0 "" {MPLTEXT 1 0 21 "d := 0.5;tend := 500;" }{MPLTEXT 1 0 0 
"" }}{PARA 235 "> " 0 "" {MPLTEXT 1 0 71 "sol := dsolve(\{sys, ic\}, t
ype=numeric, maxfun=-1,output=listprocedure);" }{MPLTEXT 1 0 0 "" }}
{PARA 235 "> " 0 "" {MPLTEXT 1 0 134 "odeplot(sol, [x(t), y(t), z(t)],
 tend/2..tend, labels=[\"x\",\"y\",\"z\"],view=[0..4,0..4,0..4], numpo
ints=tend*100,color=blue,axes=normal);" }{MPLTEXT 1 0 0 "" }}}{EXCHG 
{PARA 237 "" 0 "" {TEXT 212 0 "" }}{PARA 237 "" 0 "" {TEXT 212 28 "d <
 0.28: stable fixed point" }{TEXT 212 0 "" }}{PARA 237 "" 0 "" {TEXT 
212 27 "0.28 < d < 0.4: limit cycle" }{TEXT 212 0 "" }}{PARA 237 "" 0 
"" {TEXT 212 27 "d > 0.42: strange attractor" }{TEXT 212 0 "" }}{PARA 
237 "" 0 "" {TEXT 212 0 "" }}}{EXCHG {PARA 237 "" 0 "" {TEXT 212 0 "" 
}}{PARA 236 "" 0 "" {TEXT 203 43 "c. - Calculate fixed points for vari
able d." }{TEXT 203 0 "" }}{PARA 237 "" 0 "" {TEXT 212 0 "" }}}{EXCHG 
{PARA 235 "> " 0 "" {MPLTEXT 1 0 9 "d := 'd';" }{MPLTEXT 1 0 0 "" }}}
{EXCHG {PARA 235 "> " 0 "" {MPLTEXT 1 0 56 "solve(\{f1(x,y,z)=0, f2(x,
y,z)=0, f3(x,y,z)=0\}, \{x,y,z\});" }{MPLTEXT 1 0 0 "" }}}{EXCHG 
{PARA 235 "> " 0 "" {MPLTEXT 1 0 98 "fp := \{z = 0., x = 0., y = 0.\},
 \{z = 1.212747108, x = .2908429723, y = .6183140554+2.425494217*d\};"
 }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 237 "" 0 "" {TEXT 212 0 "" }}
{PARA 237 "" 0 "" {TEXT 212 45 "The fixed points are given in the vari
able fp" }{TEXT 212 0 "" }}{PARA 237 "" 0 "" {TEXT 212 0 "" }}}{EXCHG 
{PARA 238 "" 0 "" {TEXT 215 0 "" }}{PARA 239 "" 0 "" {TEXT 216 28 "d -
 stability of fixed point" }{TEXT 216 0 "" }}{PARA 238 "" 0 "" {TEXT 
215 0 "" }}}{EXCHG {PARA 234 "> " 0 "" {MPLTEXT 1 205 27 "jac11 := dif
f(f1(x,y,z),x):" }{MPLTEXT 1 205 54 "jac12 := diff(f1(x,y,z),y):jac13 \+
:= diff(f1(x,y,z),z):" }{MPLTEXT 1 205 0 "" }}{PARA 234 "> " 0 "" 
{MPLTEXT 1 205 27 "jac21 := diff(f2(x,y,z),x):" }{MPLTEXT 1 205 54 "ja
c22 := diff(f2(x,y,z),y):jac23 := diff(f2(x,y,z),z):" }{MPLTEXT 1 205 
0 "" }}{PARA 234 "> " 0 "" {MPLTEXT 1 205 27 "jac31 := diff(f3(x,y,z),
x):" }{MPLTEXT 1 205 54 "jac32 := diff(f3(x,y,z),y):jac33 := diff(f3(x
,y,z),z):" }{MPLTEXT 1 205 0 "" }}{PARA 235 "> " 0 "" {MPLTEXT 1 0 82 
"jacmat := Matrix([[jac11,jac12,jac13],[jac21,jac22,jac23],[jac31, jac
32, jac33]]);" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 235 "> " 0 "" 
{MPLTEXT 1 0 28 "jacfp := subs(fp[2],jacmat);" }{MPLTEXT 1 0 0 "" }}}
{EXCHG {PARA 234 "> " 0 "" {MPLTEXT 1 205 40 "ev1 := Eigenvalues(subs(
d=0.25, jacfp));" }{MPLTEXT 1 205 0 "" }}}{EXCHG {PARA 240 "> " 0 "" 
{MPLTEXT 1 217 40 "ev2 := Eigenvalues(subs(d=0.35, jacfp));" }
{MPLTEXT 1 217 0 "" }}}{EXCHG {PARA 240 "> " 0 "" {MPLTEXT 1 217 41 "e
v3 := Eigenvalues(subs(d=0.295, jacfp));" }{MPLTEXT 1 217 0 "" }}}
