{SECT 0 {EXCHG {PARA 200 "> " 0 "" {MPLTEXT 1 0 57 "restart; with(plot
s): with(LinearAlgebra): with(DEtools):" }{MPLTEXT 1 0 0 "" }}}{EXCHG 
{PARA 201 "" 0 "" {TEXT 205 0 "" }}{PARA 201 "" 0 "" {TEXT 205 73 "Wit
h x1 = N1/K1, x2 := N2/K2, b1 =a1K2,  b2=a2 K1, the system becomes ...
" }{TEXT 205 0 "" }}{PARA 201 "" 0 "" {TEXT 205 0 "" }}}{EXCHG {PARA 
200 "> " 0 "" {MPLTEXT 1 0 50 "f1 := (x1, x2) -> r1 * x1 * (1-x1) - b1
 * x1 * x2;" }{MPLTEXT 1 0 0 "" }}{PARA 200 "> " 0 "" {MPLTEXT 1 0 50 
"f2 := (x1, x2) -> r2 * x2 * (1-x2) - b2 * x1 * x2;" }{MPLTEXT 1 0 0 "
" }}}{EXCHG {PARA 201 "" 0 "" {TEXT 205 0 "" }}{PARA 201 "" 0 "" 
{TEXT 205 36 "Determination of the fixed points..." }{TEXT 205 0 "" }}
{PARA 201 "" 0 "" {TEXT 205 0 "" }}}{EXCHG {PARA 200 "> " 0 "" 
{MPLTEXT 1 0 49 "fp :=solve(\{f1(x1, x2)=0, f2(x1, x2)=0\},\{x1,x2\});
" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 201 "" 0 "" {TEXT 205 93 "4 possi
bilities: all species extinct, species 2 extinct, species 1 extinct, a
nd co-existence " }{TEXT 205 0 "" }}}{EXCHG {PARA 201 "" 0 "" {TEXT 
205 0 "" }}{PARA 201 "" 0 "" {TEXT 205 40 "Phase-plane plots, define t
he system ..." }{TEXT 205 0 "" }}{PARA 201 "" 0 "" {TEXT 205 0 "" }}}
{EXCHG {PARA 200 "> " 0 "" {MPLTEXT 1 0 41 "eq1 := diff(x1(t), t) = f1
(x1(t), x2(t));" }{MPLTEXT 1 0 0 "" }}{PARA 200 "> " 0 "" {MPLTEXT 1 
0 41 "eq2 := diff(x2(t), t) = f2(x1(t), x2(t));" }{MPLTEXT 1 0 0 "" }}
{PARA 200 "> " 0 "" {MPLTEXT 1 0 15 "sys := eq1,eq2;" }{MPLTEXT 1 0 0 
