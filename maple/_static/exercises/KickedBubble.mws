"> " 0 "" {MPLTEXT 1 240 27 "evneg := Eigenvalues(Jneg);" }{MPLTEXT 1 
240 0 "" }}}{EXCHG {PARA 266 "" 0 "" {TEXT 241 0 "" }}{PARA 266 "" 0 "
" {TEXT 241 102 "Here Maple is a bit silly as it does not use the iden
tity cos^2 x + sin^2 x = 1. Doing this gives that" }{TEXT 241 0 "" }}
{PARA 266 "" 0 "" {TEXT 241 0 "" }}{PARA 266 "" 0 "" {TEXT 241 54 "ev1
 = exp(-mu tau) (cos(omega tau) + i sin(omega tau))" }{TEXT 241 0 "" }
}{PARA 266 "" 0 "" {TEXT 241 0 "" }}{PARA 266 "" 0 "" {TEXT 241 54 "ev
2 = exp(-mu tau) (cos(omega tau) - i sin(omega tau))" }{TEXT 241 0 "" 
}}{PARA 266 "" 0 "" {TEXT 241 0 "" }}{PARA 266 "" 0 "" {TEXT 241 55 "t
his means that: abs(ev1) = abs(ev2) = exp(-mu tau) < 1" }{TEXT 241 0 "
" }}{PARA 266 "" 0 "" {TEXT 241 0 "" }}{PARA 266 "" 0 "" {TEXT 241 32 
"Let's plot this just to be sure." }{TEXT 241 0 "" }}{PARA 266 "" 0 ""
