{TEXT 231 0 "" }}{PARA 269 "" 0 "" {TEXT 233 0 "" }}}{EXCHG {PARA 265 
"> " 0 "" {MPLTEXT 1 240 62 "Jneg := VectorCalculus:-Jacobian([fneg(x,
y), g(x,y)], [x, y]);" }{MPLTEXT 1 240 0 "" }}}{EXCHG {PARA 266 "" 0 "
" {TEXT 241 0 "" }}{PARA 266 "" 0 "" {TEXT 241 85 "Note that there is \+
no need to substitute the fixed points as this is a linear system!" }
