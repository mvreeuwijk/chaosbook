}}{EXCHG {PARA 205 "> " 0 "" {MPLTEXT 1 0 25 "sp2:=pointplot3d([seq([x
c" }{MPLTEXT 1 -1 3 "[m]" }{MPLTEXT 1 0 64 ",yc[m],zc[m]],m=1..n)],col
or=black,symbol=circle,symbolsize=10):" }{MPLTEXT 1 0 0 "" }}}{EXCHG 
