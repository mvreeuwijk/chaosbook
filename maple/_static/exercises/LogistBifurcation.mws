{PARA 208 "> " 0 "" {MPLTEXT 1 0 14 "xs[1] := 0.57:" }{MPLTEXT 1 0 0 "
" }}}{EXCHG {PARA 208 "> " 0 "" {MPLTEXT 1 0 21 "for i from 0 to Nr do
