" {MPLTEXT 1 0 3 "od:" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 33 "pt
s := seq([xl[i],yl[i]],i=1..N):" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 
