{EXCHG }{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 20 "for i from 1 to N do
" }}{PARA 0 "> " 0 "" {MPLTEXT 1 0 20 "xl[i] := data[i][1];" }}{PARA 
