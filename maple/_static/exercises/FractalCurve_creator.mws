  if ( dd < 1 ) then" }}{PARA 0 "> " 0 "" {MPLTEXT 1 0 9 "      p1;" }
}{PARA 0 "> " 0 "" {MPLTEXT 1 0 7 "   else" }}{PARA 0 "" 0 "" {TEXT 
