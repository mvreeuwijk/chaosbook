\renewenvironment{sphinxadmonition}[2]{%
    \def\admonitionbg{lightgrey}%
    \def\admontitle{#2}%
    \def\MapleTitle{Maple}%
    \def\MapleCodeTitle{Maple code}%
    \def\admonitionfontsize{}%
    \ifx\admontitle\MapleTitle
      \def\admonitionbg{mapleyellow}%
      \def\admonitionfontsize{\small}%
    \fi
    \ifx\admontitle\MapleCodeTitle
      \def\admonitionbg{mapleyellow}%
      \def\admonitionfontsize{\small}%
    \fi
    \begin{tcolorbox}[
        colframe=white,              % No border
        colback=\admonitionbg,       % Per-title background
        sharp corners,               % Square corners
        boxrule=0pt,                 % No border width
        left=10pt, right=10pt,       % Internal padding
        top=5pt, bottom=5pt          % Internal padding
    ]
    \dbend\ \textbf{#2}\par % Display the title (e.g., "Hint:") in bold
    \begingroup
    \admonitionfontsize
    \setlength{\parindent}{2em}%
    \everypar{%
      \ifnum\prevgraf=0\relax
        \setlength{\parindent}{2em}%
      \else
        \setlength{\parindent}{0pt}%
      \fi
    }% Indent first paragraph only (content)
}{%
    \endgroup
    \end{tcolorbox}
}
\makeatother

