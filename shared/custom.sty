% --- Custom theorem counters for proof environments ---

% Separate counters per type, reset per chapter
\newtheorem{definitioncounter}{Definition}[chapter]
\newtheorem{exercisecounter}{Exercise}[chapter]
\newtheorem{tutorialcounter}{Tutorial}[chapter]

% Redefine the environments created by sphinxcontrib-proof to use these
% NOTE: defer until after Sphinx defines the environments
\AtBeginDocument{%
  \ifdefined\definition
    \let\olddefinition\definition
    \let\oldenddefinition\enddefinition
    \renewenvironment{definition}{%
      \begin{definitioncounter}%
    }{%
      \end{definitioncounter}%
    }
  \fi

  \ifdefined\exercise
    \let\oldexercise\exercise
    \let\oldendexercise\endexercise
    \renewenvironment{exercise}{%
      \begin{exercisecounter}%
    }{%
      \end{exercisecounter}%
    }
  \fi

  \ifdefined\tutorial
    \let\oldtutorial\tutorial
    \let\oldendtutorial\endtutorial
    \renewenvironment{tutorial}{%
      \par\noindent\hrulefill\par
      \begin{tutorialcounter}%
    }{%
      \end{tutorialcounter}%
    }
  \fi
}
