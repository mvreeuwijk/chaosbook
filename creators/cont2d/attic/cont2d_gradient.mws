):" }}}{EXCHG {PARA 0 "" 0 "" {TEXT 206 0 "" }}{PARA 0 "> " 0 "" 
{MPLTEXT 1 0 27 "V := (x, y) -> a*x^2+b*y^2;" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "f*6$I\"xG6\"I\"yGF%F%6$I)operatorGF%I&arrowGF%F%,&*&I\"aG
F%\"\"\"9$\"\"#F-*&I\"bGF%F-9%F/F-F%F%F%" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 16 "par1 := a=1,b=2;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6$/
I\"aG6\"\"\"\"/I\"bGF%\"\"#" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 
18 "par2 := a=1, b=-2;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6$/I\"aG6\"\"
\"\"/I\"bGF%!\"#" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 23 "P := Ar
ray(1..1, 1..2);" }}{PARA 11 "" 1 "" {XPPMATH 20 "-I&ArrayG%*protected
G6#/I$%idG6\"\"*/XBY&" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 78 "P[
1,1] := plot3d(subs(par1, V(x, y)), x = -2 .. 2, y = -2 .. 2, axes = b
oxed):" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 18 "p1 := contourplot
(" }{MPLTEXT 1 0 110 "subs(par1, V(x, y)), x = -2 .. 2, y = -2 .. 2, a
xes = boxed, grid=[100,100],scaling=constrained, color=black):" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 131 "p2 := gradplot(subs(par1, -
V(x,y)),x=-2..2,y=-2..2,scaling=constrained,axes=frame,thickness=2,gri
d=[15,15], arrows=slim,color=red):" }{MPLTEXT 1 0 0 "" }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 29 "P[1, 2] := display([p1, p2]);" }}
