F*F0*$F(\"\"#F0*$F.F5F0*$,&F4F0F6F0F5!\"\"F0F9/-F%6$F.F,,&F(F9*&F.F0F2
F0F9" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 12 "expand(subs(" }
{MPLTEXT 1 0 15 "x^2 = r^2-y^2, " }{MPLTEXT 1 0 67 "collect(subs(x^2 =
 r^2-y^2, (x * f(x,y) + y * g(x,y))/r), [x,y])));" }}{PARA 0 "> " 0 ""
 {MPLTEXT 1 0 20 "fr := unapply(%, r);" }}{PARA 11 "" 1 "" {XPPMATH 20
 ",(*&I\"rG6\"\"\"\"I#muGF%F&F&*$F$\"\"$F&*$F$\"\"&!\"\"" }}{PARA 11 "
" 1 "" {XPPMATH 20 "f*6#I\"rG6\"F%6$I)operatorGF%I&arrowGF%F%,(*&9$\"
\"\"I#muGF%F,F,*$F+\"\"$F,*$F+\"\"&!\"\"F%F%F%" }}}{EXCHG {PARA 0 "> "
 0 "" {MPLTEXT 1 0 107 "plotsetup(ps, plotoutput = `cont2d_global_r.ep
s`, plotoptions = `portrait,noborder,width=384, height=256`);" }
{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 29 "plot([s
ubs(mu = -.3, fr(r)), " }{MPLTEXT 1 0 24 "subs(mu = -0.2, fr(r)), " }
{MPLTEXT 1 0 137 "subs(mu = -0.1, fr(r))], r=0..1.2, thickness=2, lege
nd=['mu=-0.3', 'mu=-0.2', 'mu=-0.1'], color=black, linestyle=[solid, d
ash, dashdot]);" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 27 "ic := x(
0) = .15, y(0) = 0;" }}{PARA 0 "> " 0 "" {MPLTEXT 1 0 25 "tstart := 0;
 tend := 200;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6$/-I\"xG6\"6#\"\"!$\"#
:!\"#/-I\"yGF&F'F(" }}{PARA 11 "" 1 "" {XPPMATH 20 "\"\"!" }}{PARA 11 
"" 1 "" {XPPMATH 20 "\"$+#" }}}{EXCHG {PARA 0 "" 0 "" {TEXT 206 15 "Pl
ot timeseries" }}{PARA 0 "" 0 "" {TEXT 206 0 "" }}}{EXCHG {PARA 0 "> "
 0 "" {MPLTEXT 1 0 12 "mu := -0.26;" }}{PARA 11 "" 1 "" {XPPMATH 20 "$
!#E!\"#" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 19 "plotsetup(defaul
t);" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 112 "plotsetup(ps, ploto
utput = `cont2d_global_phase1.eps`, plotoptions = `portrait,noborder,w
idth=256, height=256`);" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 174 
"phaseportrait([DE], [x(t), y(t)], t = tstart .. tend, [[ic]], stepsiz
e = .1, x = -1.2 .. 1.2, y = -1.2 .. 1.2, color = black, linecolor = b
lack, linestyle=solid, axes=boxed);" }}}{EXCHG {PARA 0 "> " 0 "" 
