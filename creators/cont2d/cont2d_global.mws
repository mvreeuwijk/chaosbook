#" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 112 "plotsetup(ps, plotout
put = `cont2d_global_phase2.eps`, plotoptions = `portrait,noborder,wid
th=256, height=256`);" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 174 "p
