toptions = `portrait,noborder,width=384,height=256`);" }{MPLTEXT 1 0 
0 "" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 19 "plotsetup(default);"
 }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 209 "plot([Re(ev2[1]), Re(ev
2[2])], alpha = 0.12..0.5, thickness=2, labels=['alpha', 'Real(sigma)'
], legend=['sigma[1]', 'sigma[2]'], color = black, linestyle=[solid, d
ash], labeldirections=[horizontal, vertical]);" }{MPLTEXT 1 0 0 "" }}}
