{SECT 0 {EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 44 "restart; with(Linea
rAlgebra): with(DEtools):" }}{PARA 208 "> " 0 "" {MPLTEXT 1 0 0 "" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 39 "f := (x,y) -> x^2 / (x + bet
a) - x * y;" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 34 "g := (x,y) -
> x * y - alpha * y^2;" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 36 "D
E1 := diff(x(t),t) = f(x(t), y(t)):" }}{PARA 0 "> " 0 "" {MPLTEXT 1 0 
36 "DE2 := diff(y(t),t) = g(x(t), y(t)):" }}{PARA 0 "> " 0 "" {MPLTEXT
 1 0 15 "DE := DE1, DE2;" }}{PARA 0 "> " 0 "" {MPLTEXT 1 0 0 "" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 43 "fp := solve([f(x,y)=0, g(x,y
) = 0], [x,y]);" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 64 "fp := \{
op(fp)\}; # remove doubles from fp by converting to a set " }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 58 "jac := VectorCalculus[Jacobian]([f(
x,y), g(x,y)], [x, y]);" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 54 "
ev1 := Eigenvalues(subs(fp[1], jac), output = 'list');" }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 3 "ev2" }{MPLTEXT 1 0 51 " := Eigenvalu
es(subs(fp[2], jac), output = 'list');" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 13 "beta := 3/16;" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 
