{SECT 0 {EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 42 "restart; with(plots
): with(LinearAlgebra):" }}{PARA 0 "> " 0 "" {MPLTEXT 1 0 21 "f1 := (x
, y, z) -> y;" }}{PARA 0 "> " 0 "" {MPLTEXT 1 0 44 "f2 := (x, y, z) ->
 -f * y +x-x^3 + A*cos(z);" }}{PARA 0 "> " 0 "" {MPLTEXT 1 0 25 "f3 :=
 (x, y, z) -> omega;" }}{PARA 0 "> " 0 "" {MPLTEXT 1 0 44 "de1 := diff
(x(t), t) = f1(x(t), y(t), z(t));" }}{PARA 0 "> " 0 "" {MPLTEXT 1 0 
44 "de2 := diff(y(t), t) = f2(x(t), y(t), z(t));" }}{PARA 0 "> " 0 "" 
{MPLTEXT 1 0 44 "de3 := diff(z(t), t) = f3(x(t), y(t), z(t));" }}
{PARA 0 "> " 0 "" {MPLTEXT 1 0 21 "sys := de1, de2, de3;" }}{PARA 11 "
" 1 "" {XPPMATH 20 "f*6%I\"xG6\"I\"yGF%I\"zGF%F%6$I)operatorGF%I&arrow
GF%F%9%F%F%F%" }}{PARA 11 "" 1 "" {XPPMATH 20 "f*6%I\"xG6\"I\"yGF%I\"z
GF%F%6$I)operatorGF%I&arrowGF%F%,**&I\"fGF%\"\"\"9%F.!\"\"9$F.*$F1\"\"
$F0*&I\"AGF%F.-I$cosGF%6#9&F.F.F%F%F%" }}{PARA 11 "" 1 "" {XPPMATH 20 
"f*6%I\"xG6\"I\"yGF%I\"zGF%F%6$I)operatorGF%I&arrowGF%F%I&omegaGF%F%F%
F%" }}{PARA 11 "" 1 "" {XPPMATH 20 "/-I%diffG%*protectedG6$-I\"xG6\"6#
I\"tGF)F+-I\"yGF)F*" }}{PARA 11 "" 1 "" {XPPMATH 20 "/-I%diffG%*protec
tedG6$-I\"yG6\"6#I\"tGF)F+,**&I\"fGF)\"\"\"F'F/!\"\"-I\"xGF)F*F/*$F1\"
\"$F0*&I\"AGF)F/-I$cosG6$F%I(_syslibGF)6#-I\"zGF)F*F/F/" }}{PARA 11 ""
 1 "" {XPPMATH 20 "/-I%diffG%*protectedG6$-I\"zG6\"6#I\"tGF)F+I&omegaG
F)" }}{PARA 11 "" 1 "" {XPPMATH 20 "6%/-I%diffG%*protectedG6$-I\"xG6\"
6#I\"tGF*F,-I\"yGF*F+/-F%6$F-F,,**&I\"fGF*\"\"\"F-F5!\"\"F(F5*$F(\"\"$
F6*&I\"AGF*F5-I$cosG6$F&I(_syslibGF*6#-I\"zGF*F+F5F5/-F%6$F@F,I&omegaG
F*" }}}{EXCHG {PARA 0 "" 0 "" {TEXT 206 0 "" }}{PARA 0 "" 0 "" {TEXT 
206 44 "Plot total energy of system and fixed points" }{TEXT 206 0 "" 
}}{PARA 0 "" 0 "" {TEXT 206 0 "" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 
1 0 33 "H := (x,y) -> x^4/4-x^2/2+y^2/2; " }}{PARA 0 "> " 0 "" 
{MPLTEXT 1 0 180 "p1 := contourplot(H(x,y), x=-2..2, y=-2..2, grid=[70
, 70], thickness=1, contours=[-0.15, 0, 0.5, 1, 1.5, 2, 3, 4, 5, 6, 7,
 8, 9, 10], axes=boxed, color=black, scaling=constrained):" }}{PARA 0 
"> " 0 "" {MPLTEXT 1 0 102 "p2 := plot([-1, 0, 1], [0, 0, 0], symbol=c
ircle, style=point, symbolsize=30,thickness=6, color=black):" }}{PARA 
11 "" 1 "" {XPPMATH 20 "f*6$I\"xG6\"I\"yGF%F%6$I)operatorGF%I&arrowGF%
F%,(*$9$\"\"%#\"\"\"F-*$F,\"\"##!\"\"F1*$9%F1#F/F1F%F%F%" }}}{EXCHG 
{PARA 0 "" 0 "" {TEXT 206 0 "" }}{PARA 0 "" 0 "" {TEXT 206 62 "Calcula
te double well oscillator dynamics and plot the results" }{TEXT 206 0 
"" }}{PARA 0 "" 0 "" {TEXT 206 0 "" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 32 "f := 0.15; omega := 1; A := 0.3;" }}{PARA 0 "> " 0 ""
 {MPLTEXT 1 0 35 "ic := x(0) = 0, y(0) = 0, z(0) = 0;" }}{PARA 0 "> " 
0 "" {MPLTEXT 1 0 13 "tend := 1000;" }}{PARA 0 "> " 0 "" {MPLTEXT 1 0 
71 "sol := dsolve(\{sys, ic\}, type=numeric, maxfun=-1,output=listproc
edure):" }}{PARA 0 "> " 0 "" {MPLTEXT 1 0 118 "p3 := odeplot(sol, [x(t
), y(t)], 800..tend, labels=[\"x\", \"y\"], thickness=1, color=red, nu
mpoints=tend*50,axes=normal):" }}{PARA 0 "> " 0 "" {MPLTEXT 1 0 28 "P1
 := display([p1, p3, p2]):" }}{PARA 11 "" 1 "" {XPPMATH 20 "$\"#:!\"#"
 }}{PARA 11 "" 1 "" {XPPMATH 20 "\"\"\"" }}{PARA 11 "" 1 "" {XPPMATH 
20 "$\"\"$!\"\"" }}{PARA 11 "" 1 "" {XPPMATH 20 "6%/-I\"xG6\"6#\"\"!F(
/-I\"yGF&F'F(/-I\"zGF&F'F(" }}{PARA 11 "" 1 "" {XPPMATH 20 "\"%+5" }}}
{EXCHG {PARA 0 "" 0 "" {TEXT 206 0 "" }}{PARA 0 "" 0 "" {TEXT 206 30 "
Stroboscopic Poincare section " }{TEXT 206 0 "" }}{PARA 0 "" 0 "" 
{TEXT 206 0 "" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 9 "phi := 0;" 
}}{PARA 0 "> " 0 "" {MPLTEXT 1 0 10 "N := 5000;" }}{PARA 0 "> " 0 "" 
{MPLTEXT 1 0 28 "dt := evalf(2 * Pi / omega);" }}{PARA 0 "> " 0 "" 
{MPLTEXT 1 0 38 "tlist := [seq(i*dt+phi/omega,i=1..N)]:" }}{PARA 0 "> 
" 0 "" {MPLTEXT 1 0 19 "tt := Array(tlist):" }}{PARA 0 "> " 0 "" 
{MPLTEXT 1 0 60 "sol := dsolve(\{sys, ic\}, type=numeric, maxfun=-1,ou
tput=tt):" }}{PARA 0 "> " 0 "" {MPLTEXT 1 0 18 "soldd := sol[2,1]:" }}
{PARA 0 "> " 0 "" {MPLTEXT 1 0 21 "xx := soldd[1..N, 2]:" }}{PARA 0 ">
 " 0 "" {MPLTEXT 1 0 20 "yy := soldd[1..N,3]:" }}{PARA 0 "> " 0 "" 
{MPLTEXT 1 0 36 "pp := seq([xx[i], yy[i]], i=N/2..N):" }}{PARA 0 "> " 
0 "" {MPLTEXT 1 0 74 "P2 := pointplot([pp],view=[-2..2, -1..1], labels
=[\"x\", \"y\"],symbol=point):" }}{PARA 11 "" 1 "" {XPPMATH 20 "\"\"!"
 }}{PARA 11 "" 1 "" {XPPMATH 20 "\"%+]" }}{PARA 11 "" 1 "" {XPPMATH 20
 "$\"+3`=$G'!\"*" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 19 "plotset
up(default);" }}{PARA 0 "> " 0 "" {MPLTEXT 1 0 12 "display(P1);" }}
{PARA 0 "> " 0 "" {MPLTEXT 1 0 12 "display(P2);" }}{PARA 0 "> " 0 "" 
{MPLTEXT 1 0 120 "plotsetup(ps, plotoutput = `cont3d_doublewell_phases
pace.eps`, plotoptions = `portrait,noborder,width=256, height=256`);" 
}}{PARA 0 "> " 0 "" {MPLTEXT 1 0 12 "display(P1);" }}{PARA 0 "> " 0 ""
 {MPLTEXT 1 0 118 "plotsetup(ps, plotoutput = `cont3d_doublewell_poinc
are.eps`, plotoptions = `portrait,noborder,width=384, height=256`);" }
}{PARA 0 "> " 0 "" {MPLTEXT 1 0 12 "display(P2);" }}{PARA 0 "> " 0 "" 
