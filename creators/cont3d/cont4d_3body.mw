<Group labelreference="L2" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">restart; with(plots): with(DEtools): with(plottools):</Text-field>
</Input>
</Group>
<Group labelreference="L4" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">s1 := (x,y) -&gt; sqrt((x+mu2)^2 + y^2);</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">s2 := (x,y) -&gt; sqrt((x-mu1)^2 + y^2);</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">V  := (x,y) -&gt; - mu1 / s1(x,y) - mu2 / s2(x,y) - (x^2+y^2)/2 - mu1*mu2/2;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">H  := (x,y,u,v) -&gt; (u^2+v^2)/2 + V(x,y);</Text-field>
</Input>
</Group>
<Group labelreference="L497" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">mu1 := 1-mu; mu2 := mu;</Text-field>
</Input>
</Group>
<Group labelreference="L1486" drawlabel="true">
<Input>
<Text-field style="Text" layout="Normal"></Text-field>
<Text-field style="Text" layout="Normal">Plot the potential function and find and plot the Lagrange points</Text-field>
<Text-field style="Text" layout="Normal"></Text-field>
</Input>
</Group>
<Group labelreference="L1482" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">L1 := op(maximize(V(x,0),x=1-mu..infinity, location)[2]): L1[1] := rhs(op(L1[1])): L1;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">L2 := op(maximize(V(x,0),x=-mu..1-mu, location)[2]): L2[1] := rhs(op(L2[1])): L2;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">L3 := op(maximize(V(x,0),x=-infinity..-mu, location)[2]): L3[1] := rhs(op(L3[1])): L3;</Text-field>
</Input>
</Group>
<Group labelreference="L1480" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">p1 := contourplot(exp(V(x,y)), x=-1.5..1.5, y=-1.5..1.5,axes=boxed, colour=black, thickness=1):</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">p2 := plot([L1[1], L2[1], L3[1],(1-2*mu)/2, (1-2*mu)/2], [0, 0, 0, sqrt(3)/2, -sqrt(3)/2], symbol=soliddiamond, style=point, symbolsize=20, color=red):</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">p3 := plot([1-mu], [0], symbol=solidcircle, style=point, symbolsize=20, color=black):</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">p4 := plot([-mu], [0], symbol=solidcircle, style=point, symbolsize=40, color=black):</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">p5 := plot(0,x=-1.5..1.5, linestyle=dash, color=black, thickness=1):</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">P1 := display([p1, p5, p2, p3, p4]);</Text-field>
</Input>
</Group>
<Group labelreference="L1481" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">plotsetup(default); display(P1);</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">plotsetup(ps, plotoutput=`cont4d_3body_V.eps`, plotoptions=`portrait,noborder,width=256,height=256`);</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">display(P1);</Text-field>
</Input>
</Group>
<Group labelreference="L1484" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">p1 := plot(V(x,0), x=-1.5..1.5, y=-5..0, thickness=3,colour=black):</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">p2 := plot([L1[1], L2[1], L3[1]], [L1[2], L2[2], L3[2]], symbol=soliddiamond, style=point, symbolsize=30, color=red, axes=boxed):</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">p3 := textplot([[L1[1], L1[2]+0.5, 'L1'], [L2[1], L2[2]+0.5, 'L2'], [L3[1], L3[2]+0.5, 'L3']]):</Text-field>
