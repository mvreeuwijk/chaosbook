<Group labelreference="L2" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">restart: with(plots):</Text-field>
</Input>
</Group>
<Group labelreference="L3" drawlabel="true">
<Input>
<Text-field style="Normal" layout="Normal"></Text-field>
<Text-field style="Normal" layout="Normal"><Font family="Lucida Bright">Define Rossler system</Font></Text-field>
<Text-field style="Normal" layout="Normal"></Text-field>
</Input>
</Group>
<Group labelreference="L4" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">f1 := (x,y,z) -&gt; -y-z;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">f2 := (x,y,z) -&gt; x+a*y;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">f3 := (x,y,z) -&gt;  b + z*(x-c);</Text-field>
</Input>
</Group>
<Group labelreference="L5" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">eq1 := diff(x(t),t) = f1(x(t),y(t),z(t)):</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">eq2 := diff(y(t),t) = f2(x(t),y(t),z(t)):</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">eq3 := diff(z(t),t) = f3(x(t),y(t),z(t)):</Text-field>
</Input>
</Group>
<Group labelreference="L6" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">sys:=eq1,eq2,eq3;</Text-field>
</Input>
</Group>
<Group labelreference="L7" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">ic:=(x(0)=1,y(0)=0,z(0)=0);</Text-field>
</Input>
</Group>
<Group labelreference="L8" drawlabel="true">
<Input>
<Text-field style="Normal" layout="Normal"><Font family="Lucida Bright">c=3 (period 1)</Font></Text-field>
</Input>
</Group>
<Group labelreference="L9" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">a := 0.432; b := 2; c:= 3;</Text-field>
</Input>
</Group>
<Group labelreference="L10" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">t0 := 0; t1 := 100; N := 1000;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">tt := Array(1..N, i-&gt; evalf(i/N) * (t1 - t0));</Text-field>
</Input>
</Group>
<Group labelreference="L11" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" linebreak="space" spaceabove="0" rightmargin="0" bullet="none" firstindent="0" linespacing="0.0" pagebreak-before="false" leftmargin="0" alignment="left" initial="0" spacebelow="0">sol_arr := dsolve({sys,ic},[x(t),y(t),z(t)],type=numeric,maxfun=-1,output=tt):</Text-field>
<Text-field prompt="&gt; " style="Maple Input" linebreak="space" spaceabove="0" rightmargin="0" bullet="none" firstindent="0" linespacing="0.0" pagebreak-before="false" leftmargin="0" alignment="left" initial="0" spacebelow="0">soldd:=sol_arr[2,1];</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" linebreak="space" spaceabove="0" rightmargin="0" bullet="none" firstindent="0" linespacing="0.0" pagebreak-before="false" leftmargin="0" alignment="left" initial="0" spacebelow="0">tt := soldd[1..N, 1]:</Text-field>
<Text-field prompt="&gt; " style="Maple Input" linebreak="space" spaceabove="0" rightmargin="0" bullet="none" firstindent="0" linespacing="0.0" pagebreak-before="false" leftmargin="0" alignment="left" initial="0" spacebelow="0">xx := soldd[1..N, 2]:</Text-field>
<Text-field prompt="&gt; " style="Maple Input" linebreak="space" spaceabove="0" rightmargin="0" bullet="none" firstindent="0" linespacing="0.0" pagebreak-before="false" leftmargin="0" alignment="left" initial="0" spacebelow="0">yy := soldd[1..N, 3]:</Text-field>
<Text-field prompt="&gt; " style="Maple Input" linebreak="space" spaceabove="0" rightmargin="0" bullet="none" firstindent="0" linespacing="0.0" pagebreak-before="false" leftmargin="0" alignment="left" initial="0" spacebelow="0">zz := soldd[1..N, 4]:</Text-field>
</Input>
</Group>
<Group labelreference="L12" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">pp := seq([tt[i], xx[i]], i=1..N):</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">plot([pp], labels=[&quot;t&quot;, &quot;x&quot;], color='blue');</Text-field>
</Input>
</Group>
<Group labelreference="L13" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">pp := seq([xx[i], yy[i], zz[i]], i=1..N):</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">spacecurve([pp], labels=[&quot;x&quot;, &quot;y&quot;, &quot;z&quot;], axes=normal, color=blue);</Text-field>
</Input>
</Group>
<Group labelreference="L14" drawlabel="true">
<Input>
<Text-field style="Normal" layout="Normal"><Font family="Lucida Bright">c=2, without transient ...</Font></Text-field>
</Input>
</Group>
<Group labelreference="L15" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">pp := seq([tt[i], xx[i]], i=N/2..N):</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">plot([pp], labels=[&quot;t&quot;, &quot;x&quot;], color='blue');</Text-field>
</Input>
</Group>
<Group labelreference="L16" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">pp := seq([xx[i], yy[i], zz[i]], i=N/2..N):</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">plotsetup(ps, plotoutput=`cont3d_rosslerperiod1a.eps`, plotoptions=`portrait,noborder,width=7cm,height=7cm`);</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">spacecurve([pp], labels=[&quot;x&quot;, &quot;y&quot;, &quot;z&quot;], axes=normal, color=blue, orientation=[-72,55], view=[-6..6,-6..6, 0..10]);</Text-field>
</Input>
</Group>
<Group labelreference="L17" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">pcx1 := NULL;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">for i from N/2 to N-1 do</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" linebreak="space" spaceabove="0" rightmargin="0" bullet="none" firstindent="0" linespacing="0.0" pagebreak-before="false" leftmargin="0" alignment="left" initial="0" spacebelow="0">  if(xx[i] &gt; xx[i-1] and xx[i] &gt; xx[i+1]) then</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" linebreak="space" spaceabove="0" rightmargin="0" bullet="none" firstindent="0" linespacing="0.0" pagebreak-before="false" leftmargin="0" alignment="left" initial="0" spacebelow="0">    pcx1 := pcx1, xx[i];</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" linebreak="space" spaceabove="0" rightmargin="0" bullet="none" firstindent="0" linespacing="0.0" pagebreak-before="false" leftmargin="0" alignment="left" initial="0" spacebelow="0">  end if;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" linebreak="space" spaceabove="0" rightmargin="0" bullet="none" firstindent="0" linespacing="0.0" pagebreak-before="false" leftmargin="0" alignment="left" initial="0" spacebelow="0">end do;</Text-field>
</Input>
</Group>
<Group labelreference="L18" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">plotsetup(ps, plotoutput=`cont3d_rosslerperiod1b.eps`, plotoptions=`portrait,noborder,width=7cm,height=3cm`);</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">listplot([pcx1], style=point, view=[1..nops([pcx1]), 0..8], labels=[&quot;n&quot;, &quot;x[n]&quot;], labeldirections=[horizontal, vertical], symbol=diamond, symbolsize=30);</Text-field>
</Input>
</Group>
<Group labelreference="L19" drawlabel="true">
<Input>
<Text-field style="Normal" layout="Normal"><Font family="Lucida Bright">c=3.4 (period 2)</Font></Text-field>
</Input>
</Group>
<Group labelreference="L20" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">c:=3.4;</Text-field>
</Input>
</Group>
