<Group labelreference="L1" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">restart; with(plots): </Text-field>
</Input>
</Group>
<Group labelreference="L3" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">with(LinearAlgebra): with(VectorCalculus, Jacobian):</Text-field>
</Input>
</Group>
<Group labelreference="L2" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">twopi := evalf(2*Pi);</Text-field>
</Input>
</Group>
<Group labelreference="L58" drawlabel="true">
<Input>
<Text-field style="Text" layout="Normal"></Text-field>
<Text-field style="Text" layout="Normal">* Define mod 2 pi using the floor function</Text-field>
<Text-field style="Text" layout="Normal"></Text-field>
</Input>
</Group>
<Group labelreference="L3" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">mod1 := x -&gt; x - floor(x);</Text-field>
</Input>
</Group>
<Group labelreference="L59" drawlabel="true">
<Input>
<Text-field style="Text" layout="Normal"></Text-field>
<Text-field style="Text" layout="Normal">* Define the standard map...</Text-field>
<Text-field style="Text" layout="Normal"></Text-field>
<Text-field style="Text" layout="Normal">x[n+1] = f(x[n], y[n]) = x[n] + y[n+1];</Text-field>
<Text-field style="Text" layout="Normal">y[n+1] = g(x[n], y[n]) = y[n] + K/2pi * sin(2pi x[n]);</Text-field>
<Text-field style="Text" layout="Normal"></Text-field>
</Input>
</Group>
<Group labelreference="L2" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">f := (x, y) -&gt; x + g(x, y);</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">g := (x, y) -&gt; y + K/twopi * sin(twopi * x);</Text-field>
</Input>
</Group>
<Group labelreference="L61" drawlabel="true">
<Input>
<Text-field style="Text" layout="Normal"></Text-field>
<Text-field style="Text" layout="Normal">* Calculate the Jacobian and determinant to show that the standard map is space conserving</Text-field>
<Text-field style="Text" layout="Normal"></Text-field>
</Input>
</Group>
<Group labelreference="L60" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">J := Jacobian([f(x, y), g(x, y)], [x, y]);</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">det := Determinant(J);</Text-field>
</Input>
</Group>
<Group labelreference="L67" drawlabel="true">
<Input>
<Text-field style="Text" layout="Normal"></Text-field>
<Text-field style="Text" layout="Normal">* Calculate fixed points and their stability</Text-field>
<Text-field style="Text" layout="Normal"></Text-field>
</Input>
</Group>
<Group labelreference="L70" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">K := 2;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">fp := solve([f(x, y) = x, g(x, y)=y], [x, y]);</Text-field>
</Input>
</Group>
<Group labelreference="L71" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">K := 'K';</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">ev := Eigenvalues(subs(fp[1], J));</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">plot([Re(ev[1]), Im(ev[1]), Re(ev[2]), Im(ev[2])], K=-10..10,-2..2, legend=[&quot;Re ev1&quot;, &quot;Im ev1&quot;,&quot;Re ev2&quot;, &quot;Im ev2&quot;]);</Text-field>
</Input>
</Group>
<Group labelreference="L130" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">fp := {x=0, y=0};</Text-field>
</Input>
</Group>
<Group labelreference="L131" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">J := subs(fp, J);</Text-field>
</Input>
</Group>
<Group labelreference="L129" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">(sigma,S) := Eigenvectors(J);</Text-field>
</Input>
</Group>
<Group labelreference="L133" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DD := DiagonalMatrix(sigma);</Text-field>
</Input>
</Group>
<Group labelreference="L134" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">S . DD . MatrixInverse(S);</Text-field>
</Input>
</Group>
<Group labelreference="L62" drawlabel="true">
<Input>
<Text-field style="Text" layout="Normal"></Text-field>
<Text-field style="Text" layout="Normal">* Define the mapping to display the results on a torus</Text-field>
<Text-field style="Text" layout="Normal"></Text-field>
</Input>
</Group>
<Group labelreference="L45" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">x := (u, v) -&gt; (R + r * cos(twopi * v)) * cos(twopi * u);</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">y := (u, v) -&gt; (R + r * cos(twopi * v)) * sin(twopi * u);</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">z := (u, v) -&gt; r * sin(twopi * v);</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">r := 2.5: R := 5:</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">ptorus := plot3d([x(u,v), y(u,v), z(u,v)], u=0..1, v=0..1, 
                 scaling=constrained, style=hidden, color=black):</Text-field>
</Input>
</Group>
<Group labelreference="L63" drawlabel="true">
<Input>
<Text-field style="Text" layout="Normal"></Text-field>
<Text-field style="Text" layout="Normal">* Create a standard plot with quasi-periodic behavior</Text-field>
<Text-field style="Text" layout="Normal"></Text-field>
</Input>
</Group>
<Group labelreference="L9" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">K := 2;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N := 2000; Ntrans := 1000;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">xs := Array(0..N): ys := Array(0..N):</Text-field>
</Input>
</Group>
<Group labelreference="L10" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">xs[0] := .4; ys[0] := .1;</Text-field>
</Input>
</Group>
<Group labelreference="L11" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">for n from 0 to Ntrans-1 do</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" linebreak="space" spaceabove="0" rightmargin="0" bullet="none" firstindent="0" linespacing="0.0" pagebreak-before="false" leftmargin="0" alignment="left" initial="0" spacebelow="0">  xs[n+1] := mod1(f(xs[n], ys[n]));</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" linebreak="space" spaceabove="0" rightmargin="0" bullet="none" firstindent="0" linespacing="0.0" pagebreak-before="false" leftmargin="0" alignment="left" initial="0" spacebelow="0">  ys[n+1] := mod1(g(xs[n], ys[n]));</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" linebreak="space" spaceabove="0" rightmargin="0" bullet="none" firstindent="0" linespacing="0.0" pagebreak-before="false" leftmargin="0" alignment="left" initial="0" spacebelow="0">end do:</Text-field>
</Input>
</Group>
<Group labelreference="L15" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># remove transient</Text-field>
