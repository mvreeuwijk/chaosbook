<Group labelreference="L65" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">restart; with(plots):</Text-field>
</Input>
</Group>
<Group labelreference="L3" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">with(LinearAlgebra): with(VectorCalculus, Jacobian):</Text-field>
</Input>
</Group>
<Group labelreference="L2" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">twopi := evalf(2*Pi);</Text-field>
</Input>
</Group>
<Group labelreference="L64" drawlabel="true">
<Input>
<Text-field style="Text" layout="Normal"></Text-field>
<Text-field style="Text" layout="Normal">* Define mod 2 pi using the floor function</Text-field>
<Text-field style="Text" layout="Normal"></Text-field>
</Input>
</Group>
<Group labelreference="L63" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">mod1 := x -&gt; x - floor(x);</Text-field>
</Input>
</Group>
<Group labelreference="L61" drawlabel="true">
<Input>
<Text-field style="Text" layout="Normal"></Text-field>
<Text-field style="Text" layout="Normal">* Define the standard map...</Text-field>
<Text-field style="Text" layout="Normal"></Text-field>
<Text-field style="Text" layout="Normal">x[n+1] = f(x[n], y[n]) = x[n] + y[n+1];</Text-field>
<Text-field style="Text" layout="Normal">y[n+1] = g(x[n], y[n]) = y[n] + K/2pi * sin(2pi x[n]);</Text-field>
<Text-field style="Text" layout="Normal"></Text-field>
</Input>
</Group>
<Group labelreference="L62" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">f := (x, y) -&gt; x + g(x, y);</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">g := (x, y) -&gt; y + K/twopi * sin(twopi * x);</Text-field>
</Input>
</Group>
<Group labelreference="L99" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">K := 2;</Text-field>
</Input>
</Group>
<Group labelreference="L92" drawlabel="true">
<Input>
<Text-field style="Text" layout="Normal"></Text-field>
<Text-field style="Text" layout="Normal">Create a parametric description of a line on the x-axis...</Text-field>
<Text-field style="Text" layout="Normal"></Text-field>
</Input>
</Group>
<Group labelreference="L69" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">r1 := 1; r2 := 0;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">x[0] := r1 * s;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">y[0] := r2 * s; </Text-field>
</Input>
</Group>
<Group labelreference="L83" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N := 5;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">for i from 0 to N-1 do</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" linebreak="space" spaceabove="0" rightmargin="0" bullet="none" firstindent="0" linespacing="0.0" pagebreak-before="false" leftmargin="0" alignment="left" initial="0" spacebelow="0">  x[i+1] := f(x[i], y[i]);</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" linebreak="space" spaceabove="0" rightmargin="0" bullet="none" firstindent="0" linespacing="0.0" pagebreak-before="false" leftmargin="0" alignment="left" initial="0" spacebelow="0">  y[i+1] := g(x[i], y[i]);</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" linebreak="space" spaceabove="0" rightmargin="0" bullet="none" firstindent="0" linespacing="0.0" pagebreak-before="false" leftmargin="0" alignment="left" initial="0" spacebelow="0">end do;</Text-field>
</Input>
</Group>
<Group labelreference="L91" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">col := Array(0..5, [black, yellow, green, blue, brown, red]):</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">for i from 0 to N do;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">  p[i] := plot([x[i], y[i], s=-0..1], color=col[i], numpoints=1000, legend=cat(&quot;n=&quot;, i)):</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">end do;</Text-field>
</Input>
</Group>
<Group labelreference="L72" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">display(seq(p[i], i=0..N), axes=boxed);</Text-field>
</Input>
</Group>
<Group labelreference="L97" drawlabel="true">
