<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N := 10; P := 400;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle130" alignment="left" firstindent="0" spacebelow="0" linebreak="space" rightmargin="0" bulletsuffix="" pagebreak-before="false" leftmargin="0" linespacing="0.0" initial="0" layout_style_name="_pstyle130" spaceabove="0" bullet="none">X := Array(0..N): Y := Array(0..N):</Text-field>
