<Group labelreference="L1033" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">restart; with(plots): with(LinearAlgebra): with(VectorCalculus,Jacobian);</Text-field>
</Input>
</Group>
<Group labelreference="L1007" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">Digits := 800;</Text-field>
</Input>
</Group>
<Group labelreference="L1009" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle127" alignment="left" firstindent="0" spacebelow="0" linebreak="space" rightmargin="0" bulletsuffix="" pagebreak-before="false" leftmargin="0" linespacing="0.0" initial="0" layout_style_name="_pstyle127" spaceabove="0" bullet="none">f1 := (x, y) -&gt; y + 1 - a * x^2;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle127" alignment="left" firstindent="0" spacebelow="0" linebreak="space" rightmargin="0" bulletsuffix="" pagebreak-before="false" leftmargin="0" linespacing="0.0" initial="0" layout_style_name="_pstyle127" spaceabove="0" bullet="none">f2 := (x, y) -&gt; b * x;</Text-field>
</Input>
</Group>
<Group labelreference="L1055" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">J := unapply(Jacobian([f1(x,y), f2(x,y)],[x,y]),[x,y]):</Text-field>
</Input>
</Group>
<Group labelreference="L1013" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle127" alignment="left" firstindent="0" spacebelow="0" linebreak="space" rightmargin="0" bulletsuffix="" pagebreak-before="false" leftmargin="0" linespacing="0.0" initial="0" layout_style_name="_pstyle127" spaceabove="0" bullet="none">a := 1.4; b := 0.3;</Text-field>
</Input>
</Group>
<Group labelreference="L1121" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># here we start </Text-field>
</Input>
</Group>
<Group labelreference="L1122" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># a]</Text-field>
</Input>
</Group>
<Group labelreference="L1077" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N := 1; P := 4000;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle130" alignment="left" firstindent="0" spacebelow="0" linebreak="space" rightmargin="0" bulletsuffix="" pagebreak-before="false" leftmargin="0" linespacing="0.0" initial="0" layout_style_name="_pstyle130" spaceabove="0" bullet="none">X := Array(0..N): Y := Array(0..N):</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">X[N] := 0.1; Y[N] := 0.3;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">for p from 1 to P do </Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle130" alignment="left" firstindent="0" spacebelow="0" linebreak="space" rightmargin="0" bulletsuffix="" pagebreak-before="false" leftmargin="0" linespacing="0.0" initial="0" layout_style_name="_pstyle130" spaceabove="0" bullet="none">  X[0] := X[N]; Y[0] := Y[N];</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">  C := Matrix([[1,0],[0,1]]);</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle130" alignment="left" firstindent="0" spacebelow="0" linebreak="space" rightmargin="0" bulletsuffix="" pagebreak-before="false" leftmargin="0" linespacing="0.0" initial="0" layout_style_name="_pstyle130" spaceabove="0" bullet="none">  for n from 0 to N-1 do 
    X[n+1] := evalf( f1(X[n], Y[n]) );
    Y[n+1] := evalf( f2(X[n], Y[n]) );
    C := MatrixMatrixMultiply(J(X[n],Y[n]),C);
  end do:</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle130" alignment="left" firstindent="0" spacebelow="0" linebreak="space" rightmargin="0" bulletsuffix="" pagebreak-before="false" leftmargin="0" linespacing="0.0" initial="0" layout_style_name="_pstyle130" spaceabove="0" bullet="none">  lam := Eigenvalues(C):</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle130" alignment="left" firstindent="0" spacebelow="0" linebreak="space" rightmargin="0" bulletsuffix="" pagebreak-before="false" leftmargin="0" linespacing="0.0" initial="0" layout_style_name="_pstyle130" spaceabove="0" bullet="none">  Lyap1[p] := log(min(abs(lam)))/N:</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle130" alignment="left" firstindent="0" spacebelow="0" linebreak="space" rightmargin="0" bulletsuffix="" pagebreak-before="false" leftmargin="0" linespacing="0.0" initial="0" layout_style_name="_pstyle130" spaceabove="0" bullet="none">  Lyap2[p] := log(max(abs(lam)))/N:</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">end do:</Text-field>
</Input>
</Group>
<Group labelreference="L1099" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">evalf[10](add(Lyap1[p],p=1..P)/P); evalf[10](add(Lyap2[p],p=1..P)/P);</Text-field>
</Input>
</Group>
<Group labelreference="L1103" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">la := [[seq([(p-0.5)*N,Lyap1[p]],p=1..P)],[seq([(p-0.5)*N,Lyap2[p]],p=1..P)]]:</Text-field>
</Input>
</Group>
<Group labelreference="L1104" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">plot(la,style=line,thickness=1,color=[gray,gray],view=[0..P*N,-2.5..1.5]);</Text-field>
</Input>
</Group>
