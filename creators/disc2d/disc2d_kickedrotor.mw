<Group labelreference="L20" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">p3 := display(p_v, plot([[pp_v_minus], [pp_v_plus]], style=[point,point], symbolsize=[30,30], symbol=[circle, box], color=black), 
