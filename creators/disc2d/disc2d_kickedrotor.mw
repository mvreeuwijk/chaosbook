<Group labelreference="L59" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">restart; with(plots): with(plottools):</Text-field>
</Input>
</Group>
<Group labelreference="L2" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">f_theta := (theta0, v0,t) -&gt; v0 * tau / r * ( 1 - exp(-t/tau))+theta0;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">f_v := (theta0, v0, t) -&gt; v0 * exp(-t/tau);</Text-field>
</Input>
</Group>
<Group labelreference="L34" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">twopi := evalf(2 * Pi);</Text-field>
</Input>
</Group>
<Group labelreference="L32" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">S := x -&gt; K * sin(x);</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">K := 0.5; T := 10; tau := 5e8; r := 1; m := 1;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">theta[0] := .4; v[0] := .05;</Text-field>
</Input>
</Group>
<Group labelreference="L33" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">c := black, red, green, blue, cyan;</Text-field>
</Input>
</Group>
<Group labelreference="L45" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">v_minus[0] := v[0]; # dummy value to make all arrays of same length;</Text-field>
</Input>
</Group>
<Group labelreference="L63" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N := 5;</Text-field>
</Input>
</Group>
<Group labelreference="L27" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">for i from 0 to N-1 do</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" linebreak="space" spaceabove="0" rightmargin="0" bullet="none" firstindent="0" linespacing="0.0" pagebreak-before="false" leftmargin="0" alignment="left" initial="0" spacebelow="0">  theta[i+1] := evalf(f_theta(theta[i], v[i], T));</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" linebreak="space" spaceabove="0" rightmargin="0" bullet="none" firstindent="0" linespacing="0.0" pagebreak-before="false" leftmargin="0" alignment="left" initial="0" spacebelow="0">  v_minus[i+1] := evalf(f_v(theta[i], v[i], T));</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" linebreak="space" spaceabove="0" rightmargin="0" bullet="none" firstindent="0" linespacing="0.0" pagebreak-before="false" leftmargin="0" alignment="left" initial="0" spacebelow="0">  v[i+1] := evalf(v_minus[i+1] + S(theta[i+1]) / m);</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" linebreak="space" spaceabove="0" rightmargin="0" bullet="none" firstindent="0" linespacing="0.0" pagebreak-before="false" leftmargin="0" alignment="left" initial="0" spacebelow="0">end do:</Text-field>
</Input>
</Group>
<Group labelreference="L44" drawlabel="true">
<Input>
<Text-field style="Text" layout="Normal"></Text-field>
<Text-field style="Text" layout="Normal">* Create visual output</Text-field>
<Text-field style="Text" layout="Normal"></Text-field>
</Input>
</Group>
<Group labelreference="L43" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">pp_theta := [0, theta[0]]; pp_v_minus := NULL; pp_v_plus := [0, v[0]];</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">p_v := NULL; p_theta := NULL;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">for i from 1 to 5 do</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">  pp_theta := pp_theta, [i*T, theta[i]]:</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">  pp_v_minus := pp_v_minus, [i*T, v_minus[i]]:</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">  pp_v_plus := pp_v_plus, [i*T, v[i]]:</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">  p_theta := p_theta, plot(f_theta(theta[i-1], v[i-1], t-(i-1)*T), t=(i-1)*T..i*T, 
                           color=black, thickness=5):</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">#  p_theta := p_theta, textplot([(i-.9)*T, theta[i-1], cat(&quot;theta[&quot;, i-1, &quot;]&quot;)], align={RIGHT}):</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">  p_v := p_v, plot(f_v(theta[i-1], v[i-1], t-(i-1)*T), t=(i-1)*T..i*T, 
                   yrange=-1..1, color=black, thickness=5):</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">#  p_v := p_v, textplot([(i-.9)*T, v[i-1], cat(&quot;v[&quot;, i-1, &quot;]+&quot;)], align={ABOVE, RIGHT}),
              textplot([(i+.1)*T, v_minus[i], cat(&quot;v[&quot;, i, &quot;]-&quot;)], align={ABOVE, RIGHT});</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" linebreak="space" spaceabove="0" rightmargin="0" bullet="none" firstindent="0" linespacing="0.0" pagebreak-before="false" leftmargin="0" alignment="left" initial="0" spacebelow="0">end do:</Text-field>
</Input>
</Group>
<Group labelreference="L61" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">a := seq('[[i*T, 0], [i*T, S(theta[i]) / m]]', i=0..6);</Text-field>
</Input>
</Group>
<Group labelreference="L60" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">p1 := plot([a, a], t=0..50, style=[line, point], color=black, symbolsize=[20,30], thickness=[5, 1], symbol=[circle, diamond], xtickmarks=[0,10,20,30,40,50], ytickmarks=[0, 1.5], labels=[&quot;t&quot;, &quot;Fk&quot;], labeldirections=[horizontal,vertical]);</Text-field>
</Input>
</Group>
<Group labelreference="L8" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">p2 := display(p_theta, plot([pp_theta], style=point, symbol=circle,symbolsize=30, color=black),
xtickmarks=[0, 100], ytickmarks=[0=&quot;0&quot;, twopi/2=&quot;pi&quot;, twopi=&quot;2pi&quot; ], 
