<Group labelreference="L26" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">for i from 0 to nx do
  for j from 0 to ny do
    for n from 0 to N-1 do
      if( Mask[i,j] = 1 ) then 
        X[i,j,n+1] := evalf( f( X[i,j,n], Y[i,j,n] ) );
        Y[i,j,n+1] := evalf( g( X[i,j,n], Y[i,j,n] ) );
        if( abs(X[i,j,n+1]) &gt; crit ) then print(i,j); Mask[i,j] := 0; end if;
      else 
        X[i,j,n+1] := out;
        Y[i,j,n+1] := out;
      end if:
    end do:
  end do:
end do:</Text-field>
</Input>
</Group>
