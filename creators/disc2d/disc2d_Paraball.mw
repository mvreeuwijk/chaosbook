<Group labelreference="L3">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font background="[0,0,0]">restart; with(plots):</Font></Text-field>
</Input>
</Group>
<Group labelreference="L4">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font background="[0,0,0]">yb := x-&gt;x^2/2;</Font></Text-field>
</Input>
</Group>
<Group labelreference="L5">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font background="[0,0,0]">y := (x,x0,u0,v0)-&gt;yb(x0)+v0*(x-x0)/u0-1/2*(x-x0)^2/u0^2;</Font></Text-field>
</Input>
</Group>
<Group labelreference="L6">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
</Input>
</Group>
<Group labelreference="L7">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font background="[0,0,0]">fx := proc(x,u,v) (2*u*v+x*(1-u^2))/(1+u^2) end proc:</Font></Text-field>
</Input>
</Group>
<Group labelreference="L8">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font background="[0,0,0]">fu := proc(x,u,v) 
local x1, v1:
 x1 := fx(x,u,v);
 v1 := v - (x1-x)/u;
 ((1-x1^2)*u + 2*x1*v1)/(1+x1^2)
end proc:</Font></Text-field>
</Input>
</Group>
<Group labelreference="L9">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font background="[0,0,0]">fv := proc(x,u,v) 
local x1, v1:
 x1 := fx(x,u,v);
 v1 := v - (x1-x)/u;
 (2*x1*u - (1-x1^2)*v1)/(1+x1^2):
end proc:</Font></Text-field>
</Input>
</Group>
<Group labelreference="L10">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font background="[0,0,0]"># find periodic solutions</Font></Text-field>
</Input>
</Group>
<Group labelreference="L11">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font background="[0,0,0]">N := 2;</Font></Text-field>
</Input>
</Group>
<Group labelreference="L12">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font background="[0,0,0]">X := Array(0..N): Y := Array(0..N): U := Array(0..N): V := Array(0..N):</Font></Text-field>
</Input>
</Group>
<Group labelreference="L13">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font background="[0,0,0]">X[0] := -1/2; U[0] := 1/2; V[0] := v0;</Font></Text-field>
</Input>
</Group>
<Group labelreference="L14">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font background="[0,0,0]">for n from 0 to N-1 do
  X[n+1] := ( fx(X[n],U[n],V[n]) );
  U[n+1] := ( fu(X[n],U[n],V[n]) );
  V[n+1] := ( fv(X[n],U[n],V[n]) );
end do:</Font></Text-field>
</Input>
</Group>
<Group labelreference="L15">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font background="[0,0,0]">simplify(X[N]);</Font></Text-field>
</Input>
</Group>
<Group labelreference="L16">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font background="[0,0,0]">simplify(U[N]);</Font></Text-field>
</Input>
</Group>
<Group labelreference="L17">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font background="[0,0,0]">simplify(V[N]);</Font></Text-field>
</Input>
</Group>
<Group labelreference="L18">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font background="[0,0,0]">fsolve(simplify(X[N])=X[0],v0=23/8);</Font></Text-field>
</Input>
</Group>
<Group labelreference="L19">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font background="[0,0,0]">subs(v0=23/8,X[N]-X[0]); subs(v0=23/8,U[N]-U[0]); subs(v0=23/8,V[N]-V[0]);</Font></Text-field>
</Input>
</Group>
<Group labelreference="L20">
