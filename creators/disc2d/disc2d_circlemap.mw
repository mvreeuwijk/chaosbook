<Group labelreference="L42" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="_cstyle1" layout="_pstyle1">N := 200; M := 500; x0 := 0.1;</Text-field>
<Text-field prompt="&gt; " style="_cstyle1" layout="_pstyle1">domega:=1.0/M:</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">lyaps := NULL;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">xs := Array(0..N); xs[0] := x0;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="_cstyle1" layout="_pstyle1">points := NULL:</Text-field>
<Text-field prompt="&gt; " style="_cstyle1" layout="_pstyle1">for i from 0 to M do</Text-field>
<Text-field prompt="&gt; " style="_cstyle1" layout="_pstyle1">   Omega := evalf(i * domega):</Text-field>
<Text-field prompt="&gt; " style="_cstyle1" layout="_pstyle1">   for j from 0 to N-1 do</Text-field>
<Text-field prompt="&gt; " style="_cstyle1" layout="_pstyle1">      xs[j+1] := evalf( f(xs[j]) );</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="_cstyle1" layout="_pstyle1">   od:</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">   bif[i] := seq([Omega, mod1(xs[k])], k=3*N/4..N);</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">   lyap := add(log(abs(df(xs[k]))), k=N/4..N) / (.75 * N);</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">   lyaps := lyaps, [Omega, lyap/4];</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="_cstyle1" layout="_pstyle1">   W := xs[N]/N;</Text-field>
<Text-field prompt="&gt; " style="_cstyle1" layout="_pstyle1">   points := points, [Omega, W];</Text-field>
<Text-field prompt="&gt; " style="_cstyle1" layout="_pstyle1">end do:</Text-field>
</Input>
</Group>
