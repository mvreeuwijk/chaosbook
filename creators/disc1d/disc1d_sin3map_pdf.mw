d></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">pointplot([seq([n,xs[n]],n=0..N)]);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" underline="false">pdf := x -&gt; 1/(Pi*sqrt((1-x^2)));</Font></Text-field></Input></Group><Group><Input><Text-field layout="_pstyle2" prompt="&gt; " style="_cstyle1">p1 := histogram(convert(xs[0..N], list), numbars=32,color=gray):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" underline="false">p2 := plot(pdf(x),x=-0.975..0.975,thickness=5,color=black):</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">plotsetup(ps,plotoutput=`disc1d_sin3map_pdf.ps`,plotoptions=`portrait,noborder,width=8.0cm,height=7.0cm`);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" underline="false">display([p1,p2],view=[-1..1,0..1.2],labels=["x","p(x)"],axes=framed,xtickmarks=[-1,-0.5,0,0.5,1]);</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"/></Input></Group><Text-field layout="_pstyle3" style="_cstyle2"/><Text-field layout="_pstyle3" style="_cstyle2"/><Text-field layout="_pstyle3" style="_cstyle2"/><Text-field layout="_pstyle3" style="_pstyle3"/><Text-field/><Text-field/><Text-field/></Worksheet>