<Group labelreference="L2">
<Input>
<Text-field style="_cstyle3" layout="_pstyle45"></Text-field>
<Text-field style="_cstyle20" layout="_pstyle46"> Sine Map: Bifurcation</Text-field>
<Text-field style="_cstyle3" layout="_pstyle45"></Text-field>
</Input>
</Group>
<Group labelreference="L3">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle47">restart; with(plots): with(plottools):</Text-field>
</Input>
</Group>
<Group labelreference="L4">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle47">f := x -&gt; r * sin(Pi*x);</Text-field>
</Input>
</Group>
<Group labelreference="L5">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">Digits := 20;</Text-field>
</Input>
</Group>
<Group labelreference="L6">
<Input>
<Text-field style="_pstyle61" layout="_pstyle61"></Text-field>
</Input>
</Group>
<Group labelreference="L7">
<Input>
<Text-field style="Normal" layout="Normal">we have more or less located  rc</Text-field>
</Input>
</Group>
<Group labelreference="L8">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">rc := 0.86557928;</Text-field>
</Input>
</Group>
<Group labelreference="L24" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">#Nr := 250; rmin := 0.7*2.9/3; rmax := 3.62/3.56994537*rc;</Text-field>
</Input>
</Group>
<Group labelreference="L9">
<Input>
<Text-field prompt="&gt; " style="_cstyle1" layout="_pstyle48">Nr := 500; rmin := 0.53; rmax := 1;#4/3.56994537*rc;</Text-field>
</Input>
</Group>
<Group labelreference="L10">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle47">N := 1000; Nmin := ceil(0.8*N);</Text-field>
</Input>
</Group>
<Group labelreference="L11">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle47">xs := Array(1..N):</Text-field>
</Input>
</Group>
<Group labelreference="L12">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle47">xs[1] := 0.57:</Text-field>
</Input>
</Group>
<Group labelreference="L13">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle47">for i from 0 to Nr do</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">  r := evalf(rmin + (rmax - rmin)*i/Nr);</Text-field>
<Text-field style="_cstyle2" layout="_pstyle64">       Calculate the x[n] series</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle47">  for n from 1 to N-1 do xs[n+1] := evalf( f(xs[n]) ); end do:</Text-field>
<Text-field style="Text" layout="_pstyle65">      Store the converged last part as a series for plotting purposes</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle47">  pl[i] := seq([r,xs[n]],n=Nmin..N);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle47">end do:</Text-field>
</Input>
</Group>
<Group labelreference="L14">
<Input>
<Text-field style="Text" layout="_pstyle65">plot the bifurcation diagram</Text-field>
</Input>
</Group>
<Group labelreference="L31" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">gray := 0.25;</Text-field>
</Input>
</Group>
<Group labelreference="L30">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">#lrc := pointplot([[rc,0],[rc,1]],connect=true,color=COLOR(RGB,gray,gray,gray),thickness=5,linestyle=DASH): display(lrc);</Text-field>
</Input>
</Group>
<Group labelreference="L38" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">lrc := arrow([rc, 0.1], [rc, 0.3], .005/(4-2.5)*(rmax-rmin), 0.02/(4-2.5)*(rmax-rmin), 0.1, color=COLOR(RGB,gray,gray,gray)):</Text-field>
</Input>
</Group>
<Group labelreference="L16">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">bif := pointplot([seq(pl[i],i=1..Nr)],symbolsize=1,symbol=point,labels=[&quot;r&quot;, &quot;x(r)&quot;],color=black,axes=boxed):</Text-field>
