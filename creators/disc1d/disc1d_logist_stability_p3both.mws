{PARA 205 "> " 0 "" {MPLTEXT 1 0 11 "df := D(f);" }}}{EXCHG {PARA 205 
"> " 0 "" {MPLTEXT 1 0 34 "sigma[2] := df(fp2[1])*df(fp2[2]);" }}}
{EXCHG {PARA 205 "> " 0 "" {MPLTEXT 1 0 21 "solve(sigma[2]=-1,r);" }}}
{EXCHG {PARA 205 "> " 0 "" {MPLTEXT 1 0 11 "r4 := %[2];" }}}{EXCHG 
