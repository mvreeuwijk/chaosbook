{PARA 205 "> " 0 "" {MPLTEXT 1 -1 23 "fp1 := solve(f(x)-x,x);" }}}
{EXCHG {PARA 205 "> " 0 "" {MPLTEXT 1 -1 37 "eq2 := simplify((f2(x)-x)
/(f1(x)-x));" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 205 "> " 0 "" 
