{SECT 0 {EXCHG {PARA 204 "> " 0 "" {MPLTEXT 1 0 21 "restart; with(plot
s):" }}}{EXCHG {PARA 204 "> " 0 "" {MPLTEXT 1 0 13 "Digits := 20;" }}}
{EXCHG {PARA 204 "> " 0 "" {MPLTEXT 1 0 18 "f := x->r*x*(1-x);" }}}
{EXCHG {PARA 205 "> " 0 "" {MPLTEXT 1 0 14 "f1 := x->f(x);" }}}{EXCHG 
{PARA 204 "> " 0 "" {MPLTEXT 1 0 19 "f2 := x->(f@@2)(x);" }}}{EXCHG 
