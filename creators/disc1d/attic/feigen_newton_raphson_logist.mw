<Group labelreference="L1" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">restart: with(plots):</Text-field>
</Input>
</Group>
<Group labelreference="L51" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">Digits := 20; stopcrit := 10^(-Digits+2):</Text-field>
</Input>
</Group>
<Group labelreference="L2" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">f := (x,r)-&gt; r*x*(1-x);</Text-field>
</Input>
</Group>
<Group labelreference="L34" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">df := unapply(diff(f(x,r),x),[x,r]); </Text-field>
</Input>
</Group>
<Group labelreference="L37" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># define function for Newton-Raphson procedure
h := proc(r,m)
local n,X,dg,result;

X := Array(0..m); X[0] := 1/2;
for n from 0 to m-1 do X[n+1] := evalf(f(X[n],r)): end do:
dg := 0; for n from 1 to m do dg := evalf(X[n]/r + df(X[n-1],r)*dg); end do:

result := r - (X[m]-X[0])/dg;

end proc: </Text-field>
</Input>
</Group>
<Group labelreference="L61" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">P := 11; # calculations until period 2^11 = 2048 </Text-field>
</Input>
</Group>
<Group labelreference="L60" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">for p from 0 to P do
   m := 2^p;   
 # use previous value of delta for a smart start value of r
   if( p &gt;= 3 ) then 
        delta[p-2] := (rc[p-2]-rc[p-3])/(rc[p-1]-rc[p-2]);
        r[0] := rc[p-1]+(rc[p-1]-rc[p-2])/delta[p-2];
   else r[0] := 3.57;
   end if:
 # Newton-Raphson iteration to find zero-crossing of h 
   eps := 1;
   for i from 0 to 100 while eps &gt; stopcrit do
      r[i+1]  := evalf(h(r[i],m));
      eps := abs(r[i+1]-r[i]);
   end do:

   rc[p] := r[i];

end do:</Text-field>
</Input>
</Group>
<Group labelreference="L48" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># print results of r and delta
seq( print(p,rc[p],(rc[p]-rc[p-1])/(rc[p+1]-rc[p])),p=1..P-1);</Text-field>
</Input>
</Group>
