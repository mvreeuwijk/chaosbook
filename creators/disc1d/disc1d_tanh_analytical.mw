<Worksheet><Version major="6" minor="1"/><View-Properties><Zoom percentage="100"/></View-Properties><Styles><Layout alignment="left" bullet="none" firstindent="0.0" leftmargin="0.0" linebreak="space" linespacing="0.0" name="Normal" rightmargin="0.0" spaceabove="0.0" spacebelow="0.0"/><Font background="[0,0,0]" bold="true" executable="true" family="Monospaced" foreground="[255,0,0]" name="Maple Input" opaque="false" size="12"/></Styles><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">restart: with(plots): with(plottools):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">X := (n,x0) -&gt; tanh( 2^n * arctanh(x0) );</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">f := x-&gt; 2*x/(1+x^2);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">N := 15;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">xs := Array(0..N);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">x0 := 0.05; arctanh(x0);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">xs[0] := x0;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">dots := NULL;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">for n from 0 to N-1 do </Text-field></Input><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">  xs[n+1] := evalf( f(xs[n]) );</Text-field></Input><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">  dots := dots,ellipse([n,xs[n]], 0.08, 0.025, filled=true, color=black): #disks := disks, disk([n,xs[n]],0.05,color=gray):</Text-field></Input><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">end do:</Text-field></Input><Input><Text-field prompt="&gt; " style="Maple Input">p1 := plot(X(t,x0),t=0..N,numpoints=500,thickness=5,color=black,labels=["n","x[n]"],view=[-0.2..N-0.5,0..1.1],axes=boxed):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">display(p1,dots);</Text-field></Input></Group><Group><Input><Text-field leftmargin="0.0" prompt="&gt; " rightmargin="0.0" style="Maple Input">plotsetup(ps,plotoutput=`disc1d_tanh_analytical.ps`,plotoptions=`portrait,noborder,width=16.0cm,height=4.0cm`);</Text-field></Input></Group><Group><Input><Text-field leftmargin="0.0" prompt="&gt; " rightmargin="0.0"><Font style="Maple Input">display(p1,dots);</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"/></Input></Group><Text-field/><Text-field/><Text-field/><Text-field/></Worksheet>