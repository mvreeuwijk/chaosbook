 {TEXT 208 32 "       Calculate the x[n] series" }{TEXT 208 0 "" }}
{PARA 225 "> " 0 "" {MPLTEXT 1 0 24 "  for n from 1 to N-1 do" }
{MPLTEXT 1 0 0 "" }}{PARA 225 "> " 0 "" {MPLTEXT 1 0 33 "    xs[n+1] :
