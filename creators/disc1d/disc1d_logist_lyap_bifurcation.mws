ion: lambda -> 0" }{TEXT -1 0 "" }}{PARA 228 "" 0 "" {TEXT -1 17 "chao
s: lambda > 0" }{TEXT -1 0 "" }}}{EXCHG {PARA 237 "" 0 "" {TEXT -1 0 "
" }}{PARA 238 "" 0 "" {TEXT -1 50 "Lyapunov diagram combined with bifu
rcation diagram" }{TEXT -1 0 "" }}{PARA 228 "" 0 "" {TEXT -1 0 "" }}}
{EXCHG {PARA 226 "> " 0 "" {MPLTEXT 1 209 44 "N := 400; Nr := 500; rmi
n := 2.8; rmax := 4;" }{MPLTEXT 1 209 0 "" }}{PARA 225 "> " 0 "" 
{MPLTEXT 1 0 46 "Nmin := 3*N/4; Nmax := N; Npts := Nmax-Nmin+1;" }
{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 225 "> " 0 "" {MPLTEXT 1 0 43 "lyap \+
:= Array(1..Nr): rval := Array(1..Nr):" }{MPLTEXT 1 0 0 "" }}}{EXCHG 
{PARA 225 "> " 0 "" {MPLTEXT 1 0 29 "pl := Array(1..Npts*Nr,1..2):" }
{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 225 "> " 0 "" {MPLTEXT 1 0 18 "xs :=
 Array(1..N):" }{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 225 "> " 0 "" 
