"> " 0 "" {MPLTEXT 1 0 35 "    pl[j,1] := r; pl[j,2] := xs[n];" }
{MPLTEXT 1 0 0 "" }}{PARA 225 "> " 0 "" {MPLTEXT 1 0 9 "  end do:" }
