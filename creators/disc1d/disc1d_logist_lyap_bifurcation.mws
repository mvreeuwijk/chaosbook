{TEXT 208 0 "" }}{PARA 225 "> " 0 "" {MPLTEXT 1 0 24 "  for n from 1 t
o N-1 do" }{MPLTEXT 1 0 0 "" }}{PARA 225 "> " 0 "" {MPLTEXT 1 0 33 "  \+
  xs[n+1] := evalf( f(xs[n]) );" }{MPLTEXT 1 0 0 "" }}{PARA 225 "> " 0
 "" {MPLTEXT 1 0 9 "  end do:" }{MPLTEXT 1 0 0 "" }}{PARA 241 "" 0 "" 
{TEXT 201 82 "      Use the converged last part of the series to calcu
late the Lyapunov exponent" }{TEXT 201 0 "" }}{PARA 239 "> " 0 "" 
{MPLTEXT 1 -1 77 "  lyap[i] := add(evalf(log(abs(dfdx(xs[j])))), j = N
min..Nmax)/(Nmax-Nmin+1);" }{MPLTEXT 1 0 2 "  " }{MPLTEXT 1 -1 0 "" }}
{PARA 225 "> " 0 "" {MPLTEXT 1 0 15 "  rval[i] := r;" }{MPLTEXT 1 0 0 
"" }}{PARA 225 "> " 0 "" {MPLTEXT 1 0 7 "end do:" }{MPLTEXT 1 0 0 "" }
}}{EXCHG {PARA 226 "> " 0 "" {MPLTEXT 1 209 45 "lyappoints := seq([rva
l[i],lyap[i]],i=1..Nr):" }{MPLTEXT 1 209 0 "" }}}{EXCHG {PARA 226 "> "
 0 "" {MPLTEXT 1 209 89 "plot([lyappoints],thickness=1,labels=[\"r\", \+
\"lambda\"],title=\"Lyapunov-diagram\",color=red);" }{MPLTEXT 1 209 0 
"" }}}{EXCHG {PARA 228 "" 0 "" {TEXT -1 18 "stable: lambda < 0" }
