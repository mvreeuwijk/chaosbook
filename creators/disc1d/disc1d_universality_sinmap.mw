<Worksheet><Version major="6" minor="1"/><View-Properties><Zoom percentage="100"/></View-Properties><Styles><Layout leftmargin="0.0" name="_pstyle48" rightmargin="0.0"/><Layout leftmargin="0.0" name="_pstyle47" rightmargin="0.0"/><Layout leftmargin="0.0" name="_pstyle68" rightmargin="0.0"/><Layout leftmargin="0.0" name="_pstyle46" rightmargin="0.0"/><Layout leftmargin="0.0" name="_pstyle67" rightmargin="0.0"/><Layout leftmargin="0.0" name="_pstyle45" rightmargin="0.0"/><Layout leftmargin="0.0" name="_pstyle66" rightmargin="0.0"/><Layout leftmargin="0.0" name="_pstyle65" rightmargin="0.0"/><Layout leftmargin="0.0" name="_pstyle64" rightmargin="0.0"/><Layout leftmargin="0.0" name="Normal" rightmargin="0.0"/><Font background="[0,0,0]" bold="true" executable="true" family="Monospaced" foreground="[255,0,0]" name="Maple Input" readonly="false"/><Font background="[0,0,0]" bold="false" executable="false" family="Lucida Bright" foreground="[0,0,0]" italic="false" name="Text" readonly="false" size="12" underline="false"/><Font background="[0,0,0]" executable="false" family="Lucida Bright" name="_cstyle5" readonly="false"/><Font background="[0,0,0]" executable="false" family="Lucida Bright" name="_cstyle4" readonly="false"/><Font background="[0,0,0]" executable="false" family="Lucida Bright" name="_cstyle3" readonly="false"/><Font background="[0,0,0]" executable="false" family="Lucida Bright" name="_cstyle2" readonly="false"/><Font background="[0,0,0]" bold="true" executable="true" family="Monospaced" foreground="[255,0,0]" italic="false" name="_cstyle1" readonly="false" size="12" underline="false"/><Font background="[0,0,0]" executable="false" name="_pstyle68" readonly="false"/><Font background="[0,0,0]" bold="true" executable="false" family="Lucida Bright" name="_cstyle20" readonly="false" size="24"/><Font background="[0,0,0]" family="Lucida Bright" name="Page Number" underline="false"/></Styles><Page-Numbers enabled="false" first-number="1" first-numbered-page="1" horizontal-location="right" style="Page Number" vertical-location="bottom"/><Group><Input><Text-field layout="_pstyle45" style="_cstyle3"/><Text-field layout="_pstyle46" style="_cstyle20"> Sine Map: Bifurcation</Text-field><Text-field layout="_pstyle45" style="_cstyle3"/></Input></Group><Group><Input><Text-field layout="_pstyle47" prompt="&gt; " style="Maple Input">restart; with(plots): with(plottools):</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle47" prompt="&gt; " style="Maple Input">f := x -&gt; r * sin(Pi*x);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">dfdx := D(f);</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">#Digits := 20;</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">rc := 0.86557928;</Font></Text-field></Input></Group><Group><Input><Text-field layout="_pstyle48" prompt="&gt; " style="_cstyle1">Nr := 500; rmin := 0.3; rmax := rc;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">ximin := -log(rc - rmin); ximax := 10.2;</Font></Text-field></Input></Group><Group><Input><Text-field layout="_pstyle47" prompt="&gt; " style="Maple Input">N := 1000; Nmin := ceil(0.8*N);</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle47" prompt="&gt; " style="Maple Input">xs := Array(1..N):</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle47" prompt="&gt; " style="Maple Input">xs[1] := 0.57:</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle47" prompt="&gt; " style="Maple Input">for i from 0 to Nr do</Text-field><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">  xi := evalf(ximin + (ximax - ximin)*i/Nr);</Font></Text-field><Text-field layout="_pstyle47" prompt="&gt; " style="Maple Input">  r := rc - exp(-xi); #print (r);</Text-field><Text-field layout="_pstyle64" style="_cstyle2">       Calculate the x[n] series</Text-field><Text-field layout="_pstyle47" prompt="&gt; " style="Maple Input">  for n from 1 to N-1 do xs[n+1] := evalf( f(xs[n]) ); end do:</Text-field><Text-field layout="_pstyle65" style="Text">      Store the converged last part as a series for plotting purposes</Text-field><Text-field layout="_pstyle47" prompt="&gt; " style="Maple Input">  pl[i] := seq([xi,xs[n]],n=Nmin..N);</Text-field><Text-field layout="_pstyle47" prompt="&gt; " style="Maple Input">end do:</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle65" style="Text">plot the bifurcation diagram</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">ubif := pointplot([seq(pl[i],i=1..Nr)],symbolsize=1,view=[ximin..ximax,0.33..0.9],labels=["a", "x(a)"],color=black,axes=BOXED):</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">super := plot(0.5,x=<Font italic="false" size="12" underline="false">ximin-1..ximax,color=black,thickness=2):</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">display(ubif,super);</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">#read "feidatsin.txt";</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">v := 0.50000000, 0.77773377, 0.84638217, 0.86145035, 0.86469418, 0.86538967, 0.86553866, 0.86557057, 0.86557741, 0.86557887, 0.86557918, 0.86557925, 0.86557926, 0.86557927;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">xiv := seq(-log(rc-v[k]),k=1..nops([v]));</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">for k from 1 to 9 do pv[k] := plot([[xiv[k],0],[xiv[k],1]],style=line,color=black,thickness=1,linestyle=DOT): end do:</Font></Text-field><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">display(seq(pv[k],k=1..9));</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">dots := NULL;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">for k from 1 to 9 do </Text-field></Input><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">  dots := dots,ellipse([xiv[k],0.5], 0.08, 0.005, filled=true, color=black): </Text-field></Input><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">end do:</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">display(ubif,super,dots,seq(pv[k],k=1..9),view=[xiv[1]-1..xiv[7],0.33..0.9]);</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">plotsetup(ps,plotoutput=`disc1d_universality_sinmap.ps`,plotoptions=`portrait,noborder,width=10cm,height=8cm`);</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">display(ubif,super,dots,seq(pv[k],k=1..9),view=[xiv[1]-1..xiv[7],0.33..0.9]);</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">plotsetup(default);</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"/></Input></Group><Text-field layout="_pstyle66" style="_cstyle4"/><Text-field layout="_pstyle67" style="_cstyle5"/><Text-field layout="_pstyle68" style="_pstyle68"/><Text-field/><Text-field/></Worksheet>