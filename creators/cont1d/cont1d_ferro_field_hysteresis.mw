<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle6" alignment="left" firstindent="0" spacebelow="0" linebreak="space" rightmargin="0" bulletsuffix="" pagebreak-before="false" leftmargin="0" linespacing="0.0" initial="0" layout_style_name="_pstyle6" spaceabove="0" bullet="none">tinf := 100;</Text-field>
