<Group labelreference="L596" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># set state to a distorted version of pattern P</Text-field>
</Input>
</Group>
<Group labelreference="L14" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">s := xi[1..N,3];</Text-field>
</Input>
</Group>
<Group labelreference="L600" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">flip :=  ceil(0.4*N); # number of spins to be flipped</Text-field>
</Input>
</Group>
<Group labelreference="L615" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">drawspin := 1 + rand(N):</Text-field>
</Input>
</Group>
<Group labelreference="L618" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">for n from 1 to flip do 
  i := drawspin():   # draw spin at random ..
  s[i] := -s[i];      # .. and flip its state
end do:</Text-field>
</Input>
</Group>
<Group labelreference="L601" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">show_state();</Text-field>
</Input>
</Group>
<Group labelreference="L16" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">iter := 5000;</Text-field>
</Input>
</Group>
<Group labelreference="L49" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">T := 0.4;</Text-field>
</Input>
</Group>
<Group labelreference="L50" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">nrplots := 0;</Text-field>
</Input>
</Group>
<Group labelreference="L51" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
</Input>
</Group>
<Group labelreference="L631" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">for n from 0 to iter do

  # dynamics
  i := drawspin();
  field := evalf(add(J[i,j]*s[j],j=1..N)/N);
  x := evalf((1 + tanh(s[i]*field/T))/2.0);
  if( random() &gt; x ) then s[i] := -s[i]; end if; 

  # store some plots
  if( n mod 100 = 0 ) then 
    nrplots := nrplots + 1; 
    pl[nrplots] := show_state();
  end if;

  # measure correlations with all patterns
  for p from 1 to P do q[n,p] := evalf(add(s[j]*xi[j,p],j=1..N)/N); end do:

end do:</Text-field>
</Input>
</Group>
<Group labelreference="L57" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">display(seq(pl[k],k=1..nrplots),insequence=true);</Text-field>
</Input>
