<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">#
# learning phase: store patterns in J
#</Text-field>
</Input>
</Group>
<Group labelreference="L595" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">for p from 1 to P do 
  for i from 1 to N do 
    for j from 1 to N do 
       J[i,j] := J[i,j] + xi[i,p]*xi[j,p];
    end do:
  end do:
end do:</Text-field>
</Input>
</Group>
