<Group labelreference="L76" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">K := 20; </Text-field>
</Input>
</Group>
<Group labelreference="L4" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N := K*K;                 # number of spins</Text-field>
</Input>
</Group>
<Group labelreference="L67" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">P := 4;                   # number of patterns</Text-field>
</Input>
</Group>
<Group labelreference="L5" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">s  := Array(1..N,1);      # spins</Text-field>
</Input>
</Group>
<Group labelreference="L6" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">J  := Array(1..N,1..N);   # coupling matrix</Text-field>
</Input>
</Group>
<Group labelreference="L541" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">xi := Array(1..N,1..P,1); # patterns to be stored</Text-field>
</Input>
