<Group labelreference="L62" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">plot([seq([seq([n,q[n,p]],n=0..iter)],p=1..P)],view=[0..iter,-1..1],labels=[&quot;n&quot;,&quot;q[n]&quot;],title=&quot;evolution correlation&quot;,thickness=3);</Text-field>
</Input>
