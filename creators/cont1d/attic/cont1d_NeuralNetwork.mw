<Group labelreference="L8059" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">distort := proc(chi,F)
global s,N;
local i;

s := chi;
for i from 1 to N do 
  if( random() &lt; F ) then   # flip or not
     s[i] := -s[i]; 
  end if;
end do:

end proc:</Text-field>
</Input>
</Group>
<Group labelreference="L8061" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># dynamics</Text-field>
</Input>
</Group>
<Group labelreference="L8034" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">dynamics := proc(T,iter,show)
local n,i,h_i,F,p;
global s,P,pl,x,nrplots;

nrplots := 0;

for n from 0 to iter do

# dynamics

  i := choose_spin();
  h_i := evalf(add(J[i,j]*s[j],j=1..N)/N);  # calc local field
  F := evalf((1 + tanh(s[i]*h_i/T))/2.0);   # calc transition prob
  if( random() &gt; F ) then                   # flip spin or not
     s[i] := -s[i]; 
  end if; 

  # store some plots

  if( n mod show = 0 ) then 
    nrplots := nrplots + 1; 
    pl[nrplots] := show_state(s);
  end if;

  # measure correlations with all patterns
  for p from 1 to P do x[n,p] := evalf(add(s[j]*xi[j,p],j=1..N)/N); end do:

end do:
end proc:</Text-field>
</Input>
</Group>
