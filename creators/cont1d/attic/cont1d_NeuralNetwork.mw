<Group labelreference="L549" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">show_state := proc(s)       # show state 
local i,j;
global K;
  listdensityplot([seq([seq(s[j+K*(i-1)],i=1..K)],j=1..K)],range=-1..1,axes=none);
end proc:</Text-field>
</Input>
</Group>
<Group labelreference="L900" drawlabel="true">
