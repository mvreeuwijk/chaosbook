</Input>
</Group>
<Group labelreference="L598" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">R := 10000: 
random := evalf(rand(R)/R): # draw rnd nr from (0..1]</Text-field>
</Input>
</Group>
<Group labelreference="L8060" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># set state to a distorted version of pattern P</Text-field>
