    <Task-category name="&lt;default&gt;">
    </Task-category>
</Task-table>
<Task>
</Task>
<Group labelreference="L3" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">restart; with(plots):</Text-field>
</Input>
</Group>
<Group labelreference="L76" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">K := 20; </Text-field>
</Input>
</Group>
<Group labelreference="L4" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N := K*K;                   # number of neurons</Text-field>
</Input>
</Group>
<Group labelreference="L7713" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">P := 4;                     # number of patterns</Text-field>
</Input>
</Group>
<Group labelreference="L7714" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">s  := Array(1..N,1):        # neurons</Text-field>
</Input>
</Group>
<Group labelreference="L7715" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">J  := Array(1..N,1..N):     # coupling matrix</Text-field>
</Input>
</Group>
<Group labelreference="L7716" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">xi := Array(1..N,1..P,1):   # patterns to be stored</Text-field>
</Input>
</Group>
<Group labelreference="L549" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">show_state := proc(s)       # show state 
local i,j;
global K;
  listdensityplot([seq([seq(s[j+K*(i-1)],i=1..K)],j=1..K)],range=-1..1,axes=none);
end proc:</Text-field>
</Input>
</Group>
<Group labelreference="L900" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">choose_spin := 1 + rand(N): # choose spin at random</Text-field>
</Input>
</Group>
<Group labelreference="L598" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">R := 10000: 
random := evalf(rand(R)/R): # draw rnd nr from (0..1]</Text-field>
</Input>
</Group>
<Group labelreference="L7722" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># fill patterns</Text-field>
</Input>
</Group>
<Group labelreference="L7723" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">for n from 1 to N do
  if( n &gt; N/2 ) then xi[n,1] := -1; end if;
  if( n mod 2 = 0 ) then xi[n,2] := -1; end if;
  j := (n-1) mod K + 1; i := ceil(n/K); 
  if( cos(0.03*(i^2 + j^2)) &gt; 0.0 ) then xi[n,3] := -1; end if;
end do:</Text-field>
</Input>
</Group>
<Group labelreference="L7721" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">li := 68, 69, 70, 71, 72, 73, 87, 94, 106, 115, 126, 129, 130, 131, 132, 135, 145, 148, 153, 156, 165, 176, 184, 185, 196, 197, 204, 217, 224, 225, 228, 229, 232, 233, 236, 237, 245, 256, 265, 266, 275, 276, 286, 287, 294, 295, 307, 308, 309, 310, 311, 312, 313, 314, 329, 330, 331, 332:</Text-field>
</Input>
</Group>
<Group labelreference="L7720" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">for i from 1 to nops([li]) do xi[li[i],P] := -1; end do:</Text-field>
</Input>
</Group>
<Group labelreference="L7783" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># learning phase: store patterns in J</Text-field>
</Input>
</Group>
<Group labelreference="L7784" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">for p from 1 to P do 
  for i from 1 to N do 
    for j from 1 to N do 
       J[i,j] := J[i,j] + xi[i,p]*xi[j,p];
    end do:
  end do:
end do:</Text-field>
</Input>
</Group>
<Group labelreference="L7791" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># Test phase: retrieve a pattern</Text-field>
</Input>
</Group>
<Group labelreference="L635" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">s  := xi[1..N,P];       # set state equal to pattern P</Text-field>
</Input>
</Group>
<Group labelreference="L711" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">F := 0.20;              # set distort fraction </Text-field>
</Input>
</Group>
<Group labelreference="L710" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">for i from 1 to N do 
   if( random() &lt; F ) then s[i] := -s[i]; end if;
end do:</Text-field>
</Input>
</Group>
<Group labelreference="L601" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">show_state(s);</Text-field>
</Input>
</Group>
<Group labelreference="L951" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">T := 0.1;                  # set Temperature</Text-field>
</Input>
</Group>
<Group labelreference="L16" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">iter := 4000;              # set number of iterations</Text-field>
</Input>
</Group>
<Group labelreference="L50" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">nrplots := 0;</Text-field>
</Input>
</Group>
<Group labelreference="L631" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">for n from 0 to iter do

  # dynamics

  i := choose_spin();
  h_i := evalf(add(J[i,j]*s[j],j=1..N)/N);  # calc local field
  F := evalf((1 + tanh(s[i]*h_i/T))/2.0);   # calc transition prob
  if( random() &gt; F ) then                   # flip spin or not
     s[i] := -s[i]; 
  end if; 

  # store some plots

  if( n mod 100 = 0 ) then 
    nrplots := nrplots + 1; 
    pl[nrplots] := show_state(s);
  end if;

  # measure correlations with all patterns
  for p from 1 to P do x[n,p] := evalf(add(s[j]*xi[j,p],j=1..N)/N); end do:

end do:</Text-field>
</Input>
</Group>
<Group labelreference="L954" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># click in window to animate evolution of spins ...</Text-field>
</Input>
</Group>
<Group labelreference="L57" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">display(seq(pl[k],k=1..nrplots),insequence=true);</Text-field>
</Input>
</Group>
<Group labelreference="L957" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># show correlations with patterns in time</Text-field>
</Input>
</Group>
<Group labelreference="L7974" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">plot([seq([seq([n/N,x[n,p]],n=0..iter)],p=1..P)],view=[0..iter/N,-1..1],labels=[&quot;t&quot;,&quot;x(t)&quot;]);</Text-field>
</Input>
</Group>
</Worksheet>