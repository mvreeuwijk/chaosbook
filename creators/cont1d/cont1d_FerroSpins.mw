  h_i := evalf(add(s[j],j=1..N)/N);         # calc local field
  P := evalf((1 + tanh(s[i]*h_i/T))/2.0);   # calc transition prob
  if( random() &gt; P ) then                   # flip spin or not
     s[i] := -s[i]; 
  end if; 

  # store some plots

  if( n mod 1000 = 0 ) then 
    nrplots := nrplots + 1; 
    pl[nrplots] := show_state(s);
  end if;

  # store mean state
  x[n] := evalf(add(s[j],j=1..N)/N); 

end do:</Text-field>
</Input>
