<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">restart: with(plots):</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">f := T -&gt; ((1-a)*S/4-epsilon*sigma*T**4)/beta;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">sigma := 5.67e-8; beta := 4e8; S := 1370;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">a := 0.3; epsilon := 0.61;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># fixed point </Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">Teq := fsolve(f(T)=0,T=0..350);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># stability, determine the derivative in the fixed point</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">df := D(f);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">df(Teq);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># fixed point as a function of emissivity</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">epsilon := 'epsilon';</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">implicitplot(f(T),epsilon=0.3..1,T=100..400);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
</Input>
</Group>
