<Worksheet><Version major="6" minor="1"/><View-Properties><Zoom percentage="100"/></View-Properties><Styles><Layout leftmargin="0.0" name="_pstyle58" rightmargin="0.0"/><Layout leftmargin="0.0" name="_pstyle23" rightmargin="0.0"/><Layout leftmargin="0.0" name="Normal" rightmargin="0.0"/><Layout leftmargin="0.0" name="_pstyle7" rightmargin="0.0"/><Layout leftmargin="0.0" name="_pstyle3" rightmargin="0.0"/><Font background="[0,0,0]" bold="true" executable="true" family="Monospaced" foreground="[255,0,0]" name="Maple Input" readonly="false"/><Font background="[0,0,0]" executable="false" family="Lucida Bright" name="_cstyle31" readonly="false"/><Font background="[0,0,0]" executable="false" family="Lucida Bright" name="_pstyle3" readonly="false"/><Font background="[0,0,0]" executable="false" family="Lucida Bright" name="_cstyle3" readonly="false"/><Font background="[0,0,0]" bold="false" executable="false" family="Lucida Bright" foreground="[0,0,0]" italic="false" name="Normal" readonly="false" size="12" underline="false"/><Font background="[0,0,0]" family="Lucida Bright" name="Page Number" underline="false"/><Font background="[0,0,0]" executable="false" name="_pstyle58" readonly="false"/><Font background="[0,0,0]" bold="true" executable="false" family="Lucida Bright" name="_cstyle17" readonly="false" size="24"/></Styles><Page-Numbers enabled="false" first-number="1" first-numbered-page="1" horizontal-location="right" style="Page Number" vertical-location="bottom"/><Group><Input><Text-field layout="_pstyle3" style="_cstyle3"/><Text-field layout="_pstyle23" style="_cstyle17">Sensitive dependence on initital conditions in the Lorenz System</Text-field><Text-field layout="_pstyle3" style="_cstyle3"/><Text-field layout="_pstyle7" prompt="&gt; " style="Maple Input">restart; with(plots): #with(DEtools):</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle3" style="_cstyle3"/><Text-field layout="_pstyle3" style="_cstyle3">* Define  the Lorenz equations </Text-field><Text-field layout="_pstyle3" style="_cstyle3"/></Input></Group><Group><Input><Text-field layout="_pstyle7" prompt="&gt; " style="Maple Input">f1 := (x,y,z) -&gt; sigma * (y - x);</Text-field><Text-field layout="_pstyle7" prompt="&gt; " style="Maple Input">f2 := (x,y,z) -&gt; -x * z + r * x - y;</Text-field><Text-field layout="_pstyle7" prompt="&gt; " style="Maple Input">f3 := (x,y,z) -&gt;  x * y - b * z;</Text-field><Text-field layout="_pstyle7" prompt="&gt; " style="Maple Input">DE1 := diff(x(t),t) = f1(x(t),y(t),z(t)):</Text-field><Text-field layout="_pstyle7" prompt="&gt; " style="Maple Input">DE2 := diff(y(t),t) = f2(x(t),y(t),z(t)):</Text-field><Text-field layout="_pstyle7" prompt="&gt; " style="Maple Input">DE3 := diff(z(t),t) = f3(x(t),y(t),z(t));</Text-field><Text-field layout="_pstyle7" prompt="&gt; " style="Maple Input">DE := DE1, DE2, DE3;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" style="Normal"/><Text-field layout="Normal" style="Normal">* Set the parameters</Text-field><Text-field layout="Normal" style="Normal"/></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">r:=28; b:=8/3; sigma:=10;</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" style="Normal"/><Text-field layout="Normal" style="Normal">* Set the initial conditions</Text-field><Text-field layout="Normal" style="Normal"/></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">ic1 := x(0)=2,y(0)=5,z(0)=5;</Font></Text-field></Input></Group><Group><Input><Text-field layout="_pstyle3" style="_cstyle3"/><Text-field layout="_pstyle3" style="_cstyle3">* Solve system with dsolve. To see more options see the "cookbook.mws" or use the help function.</Text-field><Text-field layout="_pstyle3" style="_cstyle3"/></Input></Group><Group><Input><Text-field layout="_pstyle7" prompt="&gt; " style="Maple Input">sol1 := dsolve({DE,ic1},[x(t),y(t),z(t)],type=numeric,maxfun=-1);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" style="Normal">* Set the integration range ..</Text-field><Text-field layout="Normal" style="Normal"/><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">tstart := 0; tend:=30;</Font></Text-field></Input></Group><Group><Input><Text-field layout="_pstyle3" style="_pstyle3"/><Text-field layout="_pstyle3" style="_cstyle3">* And plot the timeseries. </Text-field><Text-field layout="Normal" style="Normal"/></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">pl := odeplot(sol1,[t,x(t)],tstart..tend,labels=["t","x"],numpoints=4000,color=black,axes=normal,thickness=2):</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">plotsetup(ps,plotoutput=`phenomenon_lorenz_xt_series.ps`,plotoptions=`portrait,noborder,width=15.0cm,height=5.0cm`);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">display(pl);</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">plotsetup(default):</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"/></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"/></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"/></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"/></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"/></Input></Group><Group><Input><Text-field layout="Normal" style="Normal">* Introduce a second initial condition </Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">#ic1 := x(0)=2,y(0)=5,z(0)=5;</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">epsilon := 1E-3;</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">ic2 := x(0)=2+epsilon,y(0)=5,z(0)=5;</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">sol1 := dsolve({DE,ic1},[x(t),y(t),z(t)],type=numeric,maxfun=-1);</Font></Text-field></Input></Group><Group><Input><Text-field layout="_pstyle7" prompt="&gt; " style="Maple Input">sol2 := dsolve({DE,ic2},[x(t),y(t),z(t)],type=numeric,maxfun=-1);</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle3" style="_cstyle3"/><Text-field layout="_pstyle3" style="_cstyle3">*Plot 2 timeseries. </Text-field><Text-field layout="_pstyle3" style="_cstyle3"/></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">tstart := 0; tend:=30;</Font></Text-field></Input></Group><Group><Input><Text-field layout="_pstyle7" prompt="&gt; " style="Maple Input">p1 := odeplot(sol1,[t,x(t)],tstart..tend,labels=["t","x"],numpoints=3000,color=gray,thickness=3,axes=normal):</Text-field><Text-field layout="_pstyle7" prompt="&gt; " style="Maple Input">p2 := odeplot(sol2,[t,x(t)],tstart..tend,labels=["t","x"],numpoints=3000,color=black,thickness=2,axes=normal):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">plotsetup(ps,plotoutput=`phenomenon_lorenz_xt_two_series_em3.ps`,plotoptions=`portrait,noborder,width=15.0cm,height=5.0cm`);</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle7" prompt="&gt; " style="Maple Input">display([p1,p2]);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"/></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">epsilon := 1E-5;</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">ic2 := x(0)=2+epsilon,y(0)=5,z(0)=5;</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">sol1 := dsolve({DE,ic1},[x(t),y(t),z(t)],type=numeric,maxfun=-1);</Font></Text-field></Input></Group><Group><Input><Text-field layout="_pstyle7" prompt="&gt; " style="Maple Input">sol2 := dsolve({DE,ic2},[x(t),y(t),z(t)],type=numeric,maxfun=-1);</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle3" style="_cstyle3"/><Text-field layout="_pstyle3" style="_cstyle3">*Plot 2 timeseries. </Text-field><Text-field layout="_pstyle3" style="_cstyle3"/></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">tstart := 0; tend:=30;</Font></Text-field></Input></Group><Group><Input><Text-field layout="_pstyle7" prompt="&gt; " style="Maple Input">p1 := odeplot(sol1,[t,x(t)],tstart..tend,labels=["t","x"],numpoints=3000,color=gray,thickness=3,axes=normal):</Text-field><Text-field layout="_pstyle7" prompt="&gt; " style="Maple Input">p2 := odeplot(sol2,[t,x(t)],tstart..tend,labels=["t","x"],numpoints=3000,color=black,thickness=2,axes=normal):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">plotsetup(ps,plotoutput=`phenomenon_lorenz_xt_two_series_em5.ps`,plotoptions=`portrait,noborder,width=15.0cm,height=5.0cm`);</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle7" prompt="&gt; " style="Maple Input">display([p1,p2]);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">plotsetup(ps,plotoutput=`phenomenon_lorenz_phasespace_close.ps`,plotoptions=`portrait,noborder,width=10.0cm,height=10.0cm`);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">odeplot(sol1,[x(t),y(t),z(t)],tstart..tend,labels=["x","y","z"],numpoints=9000,color=black,axes=normal,thickness=1,orientation=[-29,64]);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">#?plot3d</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"/></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"/></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">ic1 := x(0)=2+150,y(0)=5,z(0)=5+100;</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">ic2 := x(0)=2+50,y(0)=5,z(0)=5-100;</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">ic3 := x(0)=2-50,y(0)=5,z(0)=5+100;</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">ic4 := x(0)=2-50,y(0)=5,z(0)=5-100;</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">sol1 := dsolve({DE,ic1},[x(t),y(t),z(t)],type=numeric,maxfun=-1);</Font></Text-field></Input></Group><Group><Input><Text-field layout="_pstyle7" prompt="&gt; " style="Maple Input">sol2 := dsolve({DE,ic2},[x(t),y(t),z(t)],type=numeric,maxfun=-1);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">sol3 := dsolve({DE,ic3},[x(t),y(t),z(t)],type=numeric,maxfun=-1);</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">sol4 := dsolve({DE,ic4},[x(t),y(t),z(t)],type=numeric,maxfun=-1);</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">tstart := 0; tend:=20; tend2 := 5;</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">fat := 1;</Font></Text-field></Input></Group><Group><Input><Text-field layout="_pstyle7" prompt="&gt; " style="Maple Input">p1 := odeplot(sol1,[x(t),y(t),z(t)],tstart..tend,labels=["x","y","z"],numpoints=9000,color=black,axes=normal,thickness=fat):</Text-field><Text-field layout="_pstyle7" prompt="&gt; " style="Maple Input">p2 := odeplot(sol2,[x(t),y(t),z(t)],tstart..tend2,labels=["x","y","z"],numpoints=9000,color=black,linestyle=DASH,axes=normal,thickness=fat):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">p3 := odeplot(sol3,[x(t),y(t),z(t)],tstart..tend2,labels=["x","y","z"],numpoints=9000,color=black,</Font>linestyle=DOT,<Font italic="false" size="12" underline="false">axes=normal,thickness=fat):</Font></Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"><Font italic="false" size="12" underline="false">p4 := odeplot(sol4,[x(t),y(t),z(t)],tstart..tend2,labels=["x","y","z"],numpoints=9000,color=black,</Font>linestyle=DOT,<Font italic="false" size="12" underline="false">axes=normal,thickness=fat):</Font></Text-field></Input></Group><Group><Input><Text-field layout="_pstyle7" prompt="&gt; " style="Maple Input">plotsetup(ps,plotoutput=`phenomenon_lorenz_phasespace_far.ps`,plotoptions=`portrait,noborder,width=10.0cm,height=10.0cm`);</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle7" prompt="&gt; " style="Maple Input">display([p4,p2,p1],orientation=[-29,64]);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"/></Input></Group><Text-field layout="_pstyle58" style="_cstyle31"/><Text-field layout="_pstyle58" style="_cstyle31"/><Text-field layout="_pstyle58" style="_cstyle31"/><Text-field layout="_pstyle58" style="_cstyle31"/><Text-field layout="_pstyle58" style="_cstyle31"/><Text-field layout="_pstyle58" style="_cstyle31"/><Text-field layout="_pstyle58" style="_cstyle31"/><Text-field layout="_pstyle58" style="_cstyle31"/><Text-field layout="_pstyle58" style="_cstyle31"/><Text-field layout="_pstyle58" style="_pstyle58"/><Text-field/><Text-field/></Worksheet>