<Worksheet><Version major="6" minor="1"/><View-Properties><Zoom percentage="100"/></View-Properties><Styles><Layout alignment="left" firstindent="0.0" leftmargin="0.0" linespacing="0.0" name="_pstyle31" rightmargin="0.0" spaceabove="0.0" spacebelow="0.0"/><Layout alignment="left" firstindent="0.0" leftmargin="0.0" linebreak="space" linespacing="0.0" name="_pstyle29" rightmargin="0.0" spaceabove="0.0" spacebelow="0.0"/><Layout alignment="left" firstindent="0.0" leftmargin="0.0" linebreak="space" linespacing="0.0" name="_pstyle28" rightmargin="0.0" spaceabove="0.0" spacebelow="0.0"/><Layout alignment="left" firstindent="0.0" leftmargin="0.0" linebreak="space" linespacing="0.0" name="_pstyle27" rightmargin="0.0" spaceabove="0.0" spacebelow="0.0"/><Layout leftmargin="0.0" name="_pstyle26" rightmargin="0.0"/><Layout leftmargin="0.0" name="_pstyle42" rightmargin="0.0"/><Layout leftmargin="0.0" name="_pstyle41" rightmargin="0.0"/><Layout leftmargin="0.0" name="_pstyle40" rightmargin="0.0"/><Layout alignment="left" firstindent="0.0" leftmargin="0.0" linespacing="0.0" name="Normal" rightmargin="0.0" spaceabove="0.0" spacebelow="0.0"/><Font background="[0,0,0]" bold="true" executable="false" family="Lucida Bright" foreground="[0,0,0]" italic="false" name="_cstyle16" readonly="false" size="12" underline="false"/><Font background="[0,0,0]" bold="true" executable="false" family="Lucida Bright" foreground="[0,0,0]" italic="false" name="_cstyle15" readonly="false" size="12" underline="false"/><Font background="[0,0,0]" bold="true" executable="true" family="Monospaced" foreground="[255,0,0]" name="Maple Input" readonly="false" size="12"/><Font background="[0,0,0]" bold="false" executable="false" family="Lucida Bright" foreground="[0,0,0]" italic="false" name="_cstyle14" readonly="false" size="12" underline="false"/><Font background="[0,0,0]" bold="true" executable="true" family="Monospaced" foreground="[255,0,0]" name="_cstyle13" readonly="false" size="12"/><Font background="[0,0,0]" executable="false" family="Lucida Bright" name="_cstyle12" readonly="false"/><Font background="[0,0,0]" bold="false" executable="false" family="Lucida Bright" foreground="[0,0,0]" italic="false" name="Text" readonly="false" size="12" underline="false"/><Font background="[0,0,0]" executable="false" name="_pstyle42" readonly="false"/><Font background="[0,0,0]" executable="false" family="Lucida Bright" name="Page Number" readonly="false" size="10" underline="false"/><Font background="[0,0,0]" executable="false" family="Lucida Bright" name="_cstyle17" readonly="false"/></Styles><Page-Numbers enabled="false" first-number="1" first-numbered-page="1" horizontal-location="right" style="Page Number" vertical-location="bottom"/><Group><Input><Text-field layout="_pstyle26" prompt="&gt; " style="Maple Input">restart; with(plots): with(DEtools): with(plottools):</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle26" prompt="&gt; " style="Maple Input">xdot := (x,y,u, v) -&gt; u:</Text-field><Text-field layout="_pstyle26" prompt="&gt; " style="Maple Input">ydot := (x,y,u, v) -&gt; v:</Text-field><Text-field layout="_pstyle27" prompt="&gt; " style="_cstyle13">udot := (x,y,u, v) -&gt; G * m1 * (x1(t)-x)/d1(x,y)^3  + G * m2 * (x2(t)-x)/d2(x,y)^3:</Text-field><Text-field layout="_pstyle26" prompt="&gt; " style="Maple Input">vdot := (x,y,u, v) -&gt; G * m1 * (y1(t)-y)/d1(x,y)^3  + G * m2 * (y2(t)-y)/d2(x,y)^3:</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle26" prompt="&gt; " style="Maple Input">DE1 := diff(x(t),t) = xdot(x(t),y(t),u(t), v(t));</Text-field><Text-field layout="_pstyle26" prompt="&gt; " style="Maple Input">DE2 := diff(y(t),t) = ydot(x(t),y(t),u(t), v(t));</Text-field><Text-field layout="_pstyle26" prompt="&gt; " style="Maple Input">DE3 := diff(u(t),t) = udot(x(t),y(t),u(t), v(t));</Text-field><Text-field layout="_pstyle27" prompt="&gt; " style="_cstyle13">DE4 := diff(v(t),t) = vdot(x(t),y(t),u(t), v(t));</Text-field><Text-field layout="_pstyle26" prompt="&gt; " style="Maple Input">DE := DE1, DE2, DE3, DE4:</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle28" style="_cstyle14"/><Text-field layout="_pstyle28" style="_cstyle14">Distance from the satellite to the earth and moon, respectively.</Text-field><Text-field layout="_pstyle28" style="_cstyle14"/></Input></Group><Group><Input><Text-field layout="_pstyle27" prompt="&gt; " style="_cstyle13">d1 := (x, y) -&gt; sqrt((x - x1(t))^2 + (y-y1(t))^2);</Text-field><Text-field layout="_pstyle27" prompt="&gt; " style="_cstyle13">d2 := (x, y) -&gt; sqrt((x - x2(t))^2 + (y-y2(t))^2);</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle28" style="_cstyle14"/><Text-field layout="_pstyle28" style="_cstyle14">The orbits of the earth and the moon are assumed circular, so their paths are given as</Text-field><Text-field layout="_pstyle28" style="_cstyle14"/></Input></Group><Group><Input><Text-field layout="_pstyle27" prompt="&gt; " style="_cstyle13">x1 := t -&gt; - r1 * cos(omega * t);</Text-field><Text-field layout="_pstyle27" prompt="&gt; " style="_cstyle13">y1 := t -&gt; - r1 * sin(omega * t);</Text-field><Text-field layout="_pstyle27" prompt="&gt; " style="_cstyle13">x2 := t -&gt;   r2 * cos(omega * t);</Text-field><Text-field layout="_pstyle27" prompt="&gt; " style="_cstyle13">y2 := t -&gt;   r2 * sin(omega * t);</Text-field><Text-field layout="_pstyle27" prompt="&gt; " style="_cstyle13">r1 := R * m2 / (m1 + m2);</Text-field><Text-field layout="_pstyle27" prompt="&gt; " style="_cstyle13">r2 := R * m1 / (m1 + m2);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" style="Text">co-rotating reference frame:</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle31" prompt="&gt; " style="Maple Input">xx := (x, y, t) -&gt; x*cos(omega*t)+y*sin(omega*t);</Text-field><Text-field layout="_pstyle31" prompt="&gt; " style="Maple Input">yy := (x, y, t) -&gt; -x*sin(omega*t)+y*cos(omega*t);</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle27" prompt="&gt; " style="_cstyle13">omega := sqrt(G*(m1 + m2)/R^3);</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle28" style="_cstyle14"/><Text-field layout="_pstyle28" style="_cstyle14">Set the value of the gravitational constant.</Text-field><Text-field layout="_pstyle28" style="_cstyle14"/></Input></Group><Group><Input><Text-field layout="_pstyle27" prompt="&gt; " style="_cstyle13">G := 6.67e-11;</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle28" style="_cstyle14"/><Text-field layout="_pstyle28" style="_cstyle14">Set the mass of the earth and moon and their distance R. Note that in reality the mass of the moon is a factor 81 smaller. </Text-field><Text-field layout="_pstyle28" style="_cstyle14"/></Input></Group><Group><Input><Text-field layout="_pstyle27" prompt="&gt; " style="_cstyle13">m1 := 5.96e24; m2 := m1 / 4.0; R := 3.84e8;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">month := 30*24*3600;</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle28" style="_cstyle14"/><Text-field layout="_pstyle29" style="_cstyle15">Vary the initial position x0 and determine for which interval the system behaves chaotic. </Text-field><Text-field layout="_pstyle28" style="_cstyle14"/></Input></Group><Group><Input><Text-field layout="_pstyle28" style="_cstyle14"/><Text-field layout="_pstyle28" style="_cstyle14">The initial conditions for the satellite...</Text-field><Text-field layout="_pstyle28" style="_cstyle14"/></Input></Group><Group><Input><Text-field layout="_pstyle26" prompt="&gt; " style="Maple Input">ic := x(0) = 0.3*R, y(0) = 0, u(0) = 0, v(0) = 0;</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle26" prompt="&gt; " style="Maple Input">sol1 := dsolve({DE, ic}, [x(t), y(t), u(t), v(t)], type=numeric, maxfun=-1):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">earth := plot([x1(t)/R, y1(t)/R,t=0..2*Pi/omega],color=black,thickness=6,linestyle=SOLID):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">moon := plot([x2(t)/R, y2(t)/R,t=0..2*Pi/omega],color=black,<Font opaque="false">thickness=2,linestyle=DASH):</Font></Text-field></Input></Group><Group><Input><Text-field layout="_pstyle26" prompt="&gt; " style="Maple Input">satellite := odeplot(sol1,[x(t)/R, y(t)/R],0..2*month,numpoints=3000,color=black,labels=["x/R","y/R"]):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">plotsetup(ps,plotoutput=`phenomenon_3body_example1a.ps`,plotoptions=`portrait,noborder,width=8.0cm,height=8.0cm`);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">display([earth,moon,satellite],view=[-1.1..1.1,-1.1..1.1],axes=boxed,labels=["x/R","y/R"]);</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle28" style="_cstyle14">co-rotating frame</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">earth := disk([-r1/R, 0],0.06,color=gray): # earth location</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">moon := disk([r2/R, 0],0.03,color=gray):  # moon location</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle31" prompt="&gt; " style="Maple Input">satellite := odeplot(sol1,[xx(x(t), y(t),t)/R, yy(x(t), y(t),t)/R],0..2*month,numpoints=8000,color=black,labels=["x/R","y/R"]):</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle31" prompt="&gt; " style="Maple Input">plotsetup(ps,plotoutput=`phenomenon_3body_example1b.ps`,plotoptions=`portrait,noborder,width=8.0cm,height=8.0cm`);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">display([earth,moon,satellite],view=[-1.1..1.1,-1.1..1.1],axes=boxed,labels=["x/R",""]);</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle28" style="_cstyle14"/><Text-field layout="_pstyle28" style="_cstyle16">Some other initial positions </Text-field><Text-field layout="_pstyle28" style="_cstyle14"/></Input></Group><Group><Input><Text-field layout="_pstyle26" prompt="&gt; " style="Maple Input">ic := x(0) = 0.5*R, y(0) = 0, u(0) = 0, v(0) = 0;</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle26" prompt="&gt; " style="Maple Input">sol1 := dsolve({DE, ic}, [x(t), y(t), u(t), v(t)], type=numeric, maxfun=-1):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">earth := plot([x1(t)/R, y1(t)/R,t=0..2*Pi/omega],color=black,thickness=6,linestyle=SOLID):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">moon := plot([x2(t)/R, y2(t)/R,t=0..2*Pi/omega],color=gray<Font opaque="false">,thickness=2,linestyle=DASH):</Font></Text-field></Input></Group><Group><Input><Text-field layout="_pstyle26" prompt="&gt; " style="Maple Input">satellite := odeplot(sol1,[x(t)/R, y(t)/R],0..4*month,numpoints=3000,color=black,labels=["x/R","y/R"]):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">plotsetup(ps,plotoutput=`phenomenon_3body_example2a.ps`,plotoptions=`portrait,noborder,width=8.0cm,height=8.0cm`);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">display([earth,moon,satellite],view=[-1.1..1.1,-1.1..1.1],axes=boxed,labels=["x/R","y/R"]);</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle28" style="_cstyle14">co-rotating frame</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">earth := disk([-r1/R, 0],0.06,color=gray): # earth location</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">moon := disk([r2/R, 0],0.03,color=gray):  # moon location</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle31" prompt="&gt; " style="Maple Input">satellite := odeplot(sol1,[xx(x(t), y(t),t)/R, yy(x(t), y(t),t)/R],0..4*month,numpoints=8000,color=black,labels=["x/R","y/R"]):</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle31" prompt="&gt; " style="Maple Input">plotsetup(ps,plotoutput=`phenomenon_3body_example2b.ps`,plotoptions=`portrait,noborder,width=8.0cm,height=8.0cm`);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">display([earth,moon,satellite],view=[-1.1..1.1,-1.1..1.1],axes=boxed,labels=["x/R",""]);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"/></Input></Group><Group><Input><Text-field layout="_pstyle26" prompt="&gt; " style="Maple Input">ic := x(0) = 0.56*R, y(0) = 0, u(0) = 0, v(0) = 0;</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle26" prompt="&gt; " style="Maple Input">sol1 := dsolve({DE, ic}, [x(t), y(t), u(t), v(t)], type=numeric, maxfun=-1):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">earth := plot([x1(t)/R, y1(t)/R,t=0..2*Pi/omega],color=black,thickness=6,linestyle=SOLID):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">moon := plot([x2(t)/R, y2(t)/R,t=0..2*Pi/omega],color=gray<Font opaque="false">,thickness=2,linestyle=DASH):</Font></Text-field></Input></Group><Group><Input><Text-field layout="_pstyle26" prompt="&gt; " style="Maple Input">satellite := odeplot(sol1,[x(t)/R, y(t)/R],0..2*month,numpoints=3000,color=black,labels=["x/R","y/R"]):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">plotsetup(ps,plotoutput=`phenomenon_3body_example3a.ps`,plotoptions=`portrait,noborder,width=8.0cm,height=8.0cm`);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">display([earth,moon,satellite],view=[-1.1..1.1,-1.1..1.1],axes=boxed,labels=["x/R","y/R"]);</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle28" style="_cstyle14">co-rotating frame</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">earth := disk([-r1/R, 0],0.06,color=gray): # earth location</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">moon := disk([r2/R, 0],0.03,color=gray):  # moon location</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle31" prompt="&gt; " style="Maple Input">satellite := odeplot(sol1,[xx(x(t), y(t),t)/R, yy(x(t), y(t),t)/R],0..2*month,numpoints=8000,color=black,labels=["x/R","y/R"]):</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle31" prompt="&gt; " style="Maple Input">#plotsetup(ps,plotoutput=`phenomenon_3body_example3b.ps`,plotoptions=`portrait,noborder,width=8.0cm,height=8.0cm`);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">display([earth,moon,satellite],view=[-1.1..1.1,-1.1..1.1],axes=boxed,labels=["x/R",""]);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"/></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"/></Input></Group><Group><Input><Text-field layout="Normal" style="Text"/><Text-field layout="Normal" style="Text">two initial conditions</Text-field><Text-field layout="Normal" style="Text"/></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">epsilon := 'epsilon';</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">x0 := 0.39*R; y0 := -0.0*R;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">rsat := (x0^2+y0^2)^(1/2);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">osat := sqrt(G*(m1 + m2)/rsat^3);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">v0:= rsat*osat/1.7;</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle26" prompt="&gt; " style="Maple Input">ic1 := x(0) = x0, y(0) = y0, u(0) = 0, v(0) = v0;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">ic2 := x(0) = x0*(1+epsilon), y(0) =y0, u(0) = 0, v(0) = v0;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">epsilon := 1e-4;</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">tend := 2.2*month;</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle26" prompt="&gt; " style="Maple Input">sol1 := dsolve({DE, ic1}, [x(t), y(t), u(t), v(t)], type=numeric, maxfun=-1):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">sol2 := dsolve({DE, ic2}, [x(t), y(t), u(t), v(t)], type=numeric, maxfun=-1):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">x1e := subs(sol1(tend),x(t)); y1e := subs(sol1(tend),y(t)); </Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">x2e := subs(sol2(tend),x(t)); y2e := subs(sol2(tend),y(t));</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">earth := plot([x1(t)/R, y1(t)/R,t=0..2*Pi/omega],color=black,thickness=4,linestyle=SOLID):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">moon := plot([x2(t)/R, y2(t)/R,t=0..2*Pi/omega],color=black,thickness=2,linestyle=DASH):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">S0 := point([x0/R,y0/R],symbol=DIAMOND,color=black):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">S1 := disk([x1e/R, y1e/R],0.02,color=gray): # sat1 location</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">S2 := disk([x2e/R, y2e/R],0.02,color=black): # sat2 location</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle26" prompt="&gt; " style="Maple Input">satellite1 := odeplot(sol1,[x(t)/R, y(t)/R],0..tend,numpoints=3000,color=gray,thickness=3,labels=["x/R","y/R"]):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">satellite2 := odeplot(sol2,[x(t)/R, y(t)/R],0..tend,numpoints=3000,color=black,labels=["x/R","y/R"]):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">plotsetup(ps,plotoutput=`phenomenon_3body_example_sensitivity.ps`,plotoptions=`portrait,noborder,width=8.0cm,height=8.0cm`);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">#plotsetup(default):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">display([earth,moon,satellite1,satellite2,S0,S1,S2],view=[-1.1..1.1,-1.1..1.1],axes=boxed,labels=["x/R","y/R"]);</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle28" style="_cstyle14">co-rotating frame</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">earth := disk([-r1/R, 0],0.06,color=gray): # earth location</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">moon := disk([r2/R, 0],0.03,color=gray):  # moon location</Text-field></Input></Group><Group><Input><Text-field layout="_pstyle31" prompt="&gt; " style="Maple Input">satellite1 := odeplot(sol1,[xx(x(t), y(t),t)/R, yy(x(t), y(t),t)/R],0..tend,numpoints=3000,color=gray,thickness=3,labels=["x/R","y/R"]):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">satellite2 := odeplot(sol2,[xx(x(t), y(t),t)/R, yy(x(t), y(t),t)/R],0..tend,numpoints=3000,color=black,labels=["x/R","y/R"]):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">S0 := point([xx(x0,y0,0)/R,yy(x0,y0,0)/R],symbol=DIAMOND,color=black):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">S1 := disk([xx(x1e,y1e,tend)/R, yy(x1e,y1e,tend)/R],0.02,color=gray): # sat1 location</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">S2 := disk([xx(x2e,y2e,tend)/R, yy(x2e,y2e,tend)/R],0.02,color=black): # sat2 location</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">plotsetup(default):</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">plotsetup(ps,plotoutput=`phenomenon_3body_example_sensitivity_corot.ps`,plotoptions=`portrait,noborder,width=8.0cm,height=8.0cm`);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input">display([earth,moon,satellite1,satellite2,S0,S1,S2],view=[-1.1..1.1,-1.1..1.1],axes=boxed,labels=["x/R","y/R"]);</Text-field></Input></Group><Group><Input><Text-field layout="Normal" prompt="&gt; " style="Maple Input"/></Input></Group><Text-field layout="_pstyle40" style="_cstyle12"/><Text-field layout="_pstyle41" style="_cstyle17"/><Text-field layout="_pstyle42" style="_pstyle42"/><Text-field/><Text-field/><Text-field/><Text-field/><Text-field/><Text-field/><Text-field/><Text-field/><Text-field/><Text-field/><Text-field/></Worksheet>