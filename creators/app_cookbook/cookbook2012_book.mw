<Input>
<Text-field style="_cstyle3" layout="_pstyle150"></Text-field>
<Text-field style="_cstyle25" layout="_pstyle183">Calculation box-dimension</Text-field>
<Text-field style="_cstyle3" layout="_pstyle150"></Text-field>
</Input>
</Group>
<Group labelreference="L228" drawlabel="true">
<Input>
<Text-field style="_cstyle3" layout="_pstyle150"></Text-field>
<Text-field style="_cstyle3" layout="_pstyle150">Determine the extrema of the data</Text-field>
<Text-field style="_cstyle3" layout="_pstyle150"></Text-field>
</Input>
</Group>
<Group labelreference="L244" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">xmin := min(seq(X[i],i=1..N));</Text-field>
</Input>
</Group>
<Group labelreference="L247" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">xmax := max(seq(X[i],i=1..N));</Text-field>
</Input>
</Group>
<Group labelreference="L249" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">ymin := min(seq(Y[i],i=1..N));</Text-field>
</Input>
</Group>
<Group labelreference="L250" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">ymax := max(seq(Y[i],i=1..N));</Text-field>
</Input>
</Group>
<Group labelreference="L254" drawlabel="true">
<Input>
<Text-field style="Text" layout="Normal"> Set maximum box-size  and minimum box-size</Text-field>
</Input>
</Group>
<Group labelreference="L251" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">lmax := max(xmax-xmin,ymax-ymin);</Text-field>
</Input>
</Group>
<Group labelreference="L252" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">lmin := lmax/100;</Text-field>
</Input>
</Group>
<Group labelreference="L264" drawlabel="true">
<Input>
<Text-field style="Text" layout="Normal">set the number of different box-sizes in the analysis, pmax</Text-field>
</Input>
</Group>
<Group labelreference="L263" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">pmax := 20;</Text-field>
</Input>
</Group>
<Group labelreference="L257" drawlabel="true">
<Input>
<Text-field style="Text" layout="Normal">the box-size l[p] will vary according to l[p]= lmin*b^p, where b is such that l[pmax] = lmax</Text-field>
<Text-field style="Text" layout="Normal">calculate b:</Text-field>
</Input>
</Group>
<Group labelreference="L258" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">b := exp(log(lmax/lmin)/pmax);</Text-field>
</Input>
</Group>
<Group labelreference="L230" drawlabel="true">
<Input>
<Text-field style="_cstyle3" layout="_pstyle150"></Text-field>
<Text-field style="_cstyle3" layout="_pstyle150">Loop over all resolutions</Text-field>
<Text-field style="_cstyle3" layout="_pstyle150"></Text-field>
</Input>
</Group>
<Group labelreference="L231" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle154">boxsize := Array(0..pmax):</Text-field>
</Input>
</Group>
<Group labelreference="L286" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">boxcount := Array(0..pmax):</Text-field>
</Input>
</Group>
<Group labelreference="L285" drawlabel="true">
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle154">p := 'p':</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle154">print(&quot;p, gridsize, boxsize&quot;);</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle154">for p from pmax to 0 by -1 do</Text-field>
</Input>
<Input>
<Text-field style="_cstyle3" layout="_pstyle150">       Calculate box-size</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle154">  boxsize[p] := evalf(lmin*b^p);</Text-field>
</Input>
<Input>
<Text-field style="Text" layout="Normal">      Calculate the grid-size (ie nr of boxes)</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">  gridsize := trunc(lmax/boxsize[p])+1;</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle154">  print(p,gridsize,boxsize[p]);</Text-field>
</Input>
<Input>
<Text-field style="_cstyle3" layout="_pstyle150">       Construct the grid and set the initial values to zero</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle154">  grid := Array(1..gridsize, 1..gridsize, 0);</Text-field>
</Input>
<Input>
<Text-field style="_cstyle3" layout="_pstyle150"></Text-field>
<Text-field style="_cstyle3" layout="_pstyle150">       Mark which boxes in the grid are occupied</Text-field>
</Input>
<Input>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle154">  for n from 1 to N do</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle154">    i := trunc((X[n]-xmin)/boxsize[p])+1;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle154">    j := trunc((Y[n]-ymin)/boxsize[p])+1;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle154">    grid[i,j] := 1;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle154">  od:</Text-field>
<Text-field style="_cstyle3" layout="_pstyle150"></Text-field>
<Text-field style="_cstyle3" layout="_pstyle150">       Count number of occupied boxes</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle154">  boxcount[p] := 0;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle154">  for i from 1 to gridsize do</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle154">    for j from 1 to gridsize do</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle154">       boxcount[p] := boxcount[p] + grid[i,j];</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle154">    od;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle154">  od;</Text-field>
<Text-field style="_cstyle3" layout="_pstyle150"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="_pstyle154">od:</Text-field>
</Input>
</Group>
<Group labelreference="L232" drawlabel="true">
<Input>
<Text-field style="_cstyle3" layout="_pstyle150"></Text-field>
<Text-field style="_cstyle3" layout="_pstyle150">Plot the results in log-log fashion ...</Text-field>
<Text-field style="_cstyle3" layout="_pstyle150"></Text-field>
</Input>
</Group>
